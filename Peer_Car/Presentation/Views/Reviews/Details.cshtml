@using Peer_Car.Domain.Entities
@using Peer_Car.Domain.Enums
@model Review

@{
    ViewData["Title"] = "Review Details";
}

<div class="hero-section position-relative mb-5 bg-dark text-white py-5 shadow-sm">
    <div class="container position-relative text-center">
        <h1 class="display-4 fw-bold mb-2 animate__animated animate__fadeInDown">Review Insights</h1>
        <p class="lead mb-0 animate__animated animate__fadeInUp text-primary">Detailed feedback for @(Model.Car?.Brand ?? "Target") reservation</p>
    </div>
</div>

<div class="container mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-primary py-2"></div>

                <div class="card-body p-4 p-md-5">
                    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
                        <div>
                            <h4 class="fw-bold mb-0 text-dark">
                                <i class="bi bi-chat-left-text me-2 text-primary"></i>Review Reference
                            </h4>
                            <small class="text-muted">ID: #@Model.Id.ToString().Substring(0, 8)</small>
                        </div>
                        <div class="text-end">
                            <span class="badge bg-light text-muted border rounded-pill px-3 py-2">
                                <i class="bi bi-calendar3 me-1"></i> @Model.CreatedAt.ToString("MMMM dd, yyyy")
                            </span>
                        </div>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <h6 class="text-uppercase text-muted small fw-bold mb-3">Target Car</h6>
                            <div class="d-flex align-items-center p-3 bg-light rounded-3">
                                <div class="icon-box bg-white text-primary rounded-circle shadow-sm me-3" style="width: 45px; height: 45px; display: flex; align-items: center; justify-content: center;">
                                    <i class="bi bi-car-front fs-5"></i>
                                </div>
                                <div>
                                    <div class="fw-bold">@Model.Car?.Brand @Model.Car?.Model</div>
                                    <small class="text-muted">Year: @Model.Car?.Year</small>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <h6 class="text-uppercase text-muted small fw-bold mb-3">Reviewer Details</h6>
                            <div class="d-flex align-items-center p-3 bg-light rounded-3">
                                <div class="icon-box bg-white text-info rounded-circle shadow-sm me-3" style="width: 45px; height: 45px; display: flex; align-items: center; justify-content: center;">
                                    <i class="bi bi-person-check fs-5"></i>
                                </div>
                                <div>
                                    <div class="fw-bold">@Model.User?.FullName</div>
                                    <small class="text-muted">@Model.User?.Email</small>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="p-4 border rounded-4 bg-white shadow-sm">
                                <h6 class="text-uppercase text-muted small fw-bold mb-3">Score & Comment</h6>
                                <div class="text-warning fs-3 mb-3">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="bi bi-star@(i <= Model.Rating ? "-fill" : "")"></i>
                                    }
                                    <span class="ms-2 text-dark fs-5 fw-bold">(@Model.Rating/5)</span>
                                </div>
                                <p class="fs-5 text-dark italic lh-base mb-0">
                                    <i class="bi bi-quote fs-2 text-primary opacity-25"></i>
                                    @Model.Comment
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 pt-4 border-top">
                        <div class="d-flex flex-wrap gap-3">
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                                <i class="bi bi-arrow-left me-2"></i>Back to Feedback List
                            </a>
                            
                            @if (User.IsInRole("Admin"))
                            {
                                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Danger: Are you sure you want to delete this review?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-danger rounded-pill px-4 shadow-sm">
                                        <i class="bi bi-trash me-2"></i>Moderation: Delete Review
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-4 { border-radius: 1.5rem !important; }
    .italic { font-style: italic; }
</style>