@using Peer_Car.Domain.Entities
@model IEnumerable<Review>

@{
    ViewData["Title"] = "Reviews by Car";
    
    // تجميع التقييمات حسب العربية بطريقة أنظف
    var reviewsByCar = Model
        .GroupBy(r => new { r.CarId, Brand = r.Car?.Brand, Model = r.Car?.Model, Year = r.Car?.Year })
        .OrderBy(g => g.Key.Brand)
        .ToList();
}

<div class="hero-section position-relative mb-5 bg-dark text-white py-5 shadow-sm" style="border-radius: 0 0 2.5rem 2.5rem;">
    <div class="container position-relative text-center py-4">
        <h1 class="display-3 fw-bold mb-2 animate__animated animate__fadeInDown">Community Feedback</h1>
        <p class="lead fs-4 animate__animated animate__fadeInUp opacity-75">Explore reviews and ratings for our vehicle fleet</p>
    </div>
</div>

<div class="container mb-5">
    @if (!reviewsByCar.Any())
    {
        <div class="alert alert-light border shadow-sm rounded-4 text-center py-5">
            <i class="bi bi-chat-square-dots display-1 text-muted opacity-25 d-block mb-3"></i>
            <h4 class="fw-bold text-muted">No reviews available yet.</h4>
            <p class="text-secondary">Be the first to share your experience after your next trip!</p>
            <a asp-controller="Cars" asp-action="Index" class="btn btn-primary rounded-pill px-4 mt-3">Browse Cars</a>
        </div>
    }
    else
    {
        foreach (var carGroup in reviewsByCar)
        {
            <div class="car-group-section mb-5">
                <div class="d-flex align-items-center mb-4 border-bottom pb-2">
                    <div class="icon-circle bg-primary text-white me-3 shadow-sm" style="width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; border-radius: 12px;">
                        <i class="bi bi-car-front fs-4"></i>
                    </div>
                    <div>
                        <h3 class="fw-bold mb-0">
                            <a asp-controller="Cars" asp-action="Details" asp-route-id="@carGroup.Key.CarId" class="text-decoration-none text-dark hover-primary">
                                @carGroup.Key.Brand @carGroup.Key.Model
                            </a>
                            <span class="text-muted fw-normal fs-5 ms-2">(@carGroup.Key.Year)</span>
                        </h3>
                        <small class="text-primary fw-bold text-uppercase" style="letter-spacing: 1px;">@carGroup.Count() Reviews</small>
                    </div>
                </div>

                <div class="row g-4">
                    @foreach (var review in carGroup)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100 border-0 shadow-sm rounded-4 review-card animate__animated animate__fadeIn">
                                <div class="card-header bg-white border-0 pt-4 px-4 pb-0 d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm bg-primary-subtle text-primary rounded-circle me-2 fw-bold d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                                            @(review.User?.FullName?.Substring(0, 1).ToUpper() ?? "U")
                                        </div>
                                        <span class="fw-bold text-dark small">@review.User?.FullName</span>
                                    </div>
                                    <span class="text-muted x-small"><i class="bi bi-calendar3 me-1"></i> @review.CreatedAt.ToString("MMM dd")</span>
                                </div>
                                <div class="card-body px-4 py-3">
                                    <div class="text-warning mb-2 small">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <i class="bi bi-star@(i <= review.Rating ? "-fill" : "")"></i>
                                        }
                                    </div>
                                    <p class="card-text text-muted" style="font-size: 0.9rem; line-height: 1.5;">
                                        @if (review.Comment?.Length > 120)
                                        {
                                            @(review.Comment.Substring(0, 117) + "...")
                                        }
                                        else
                                        {
                                            @review.Comment
                                        }
                                    </p>
                                </div>
                                <div class="card-footer bg-white border-0 px-4 pb-4 mt-auto">
                                    <a asp-action="Details" asp-route-id="@review.Id" class="btn btn-link p-0 text-primary text-decoration-none fw-bold small">
                                        View Details <i class="bi bi-arrow-right ms-1"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

<style>
    .rounded-4 { border-radius: 1.25rem !important; }
    .review-card { transition: all 0.3s ease; }
    .review-card:hover { transform: translateY(-5px); box-shadow: 0 12px 24px rgba(0,0,0,0.08) !important; }
    .hover-primary:hover { color: #0d6efd !important; }
    .bg-primary-subtle { background-color: #e7f1ff; }
    .x-small { font-size: 0.75rem; }
</style>