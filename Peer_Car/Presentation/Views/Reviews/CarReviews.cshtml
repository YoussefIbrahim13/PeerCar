@using Peer_Car.Domain.Entities
@model IEnumerable<Review>

@{
    ViewData["Title"] = "Car Reviews";
    var carName = ViewBag.CarName ?? "Car Feedbacks";
}

<div class="hero-section bg-dark text-white py-5 mb-5 shadow-sm">
    <div class="container text-center">
        <h1 class="display-5 fw-bold mb-2">Reviews for @carName</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a asp-controller="Cars" asp-action="Index" class="text-primary text-decoration-none">Cars</a></li>
                <li class="breadcrumb-item active text-white-50" aria-current="page">Reviews</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            @if (!Model.Any())
            {
                <div class="text-center py-5 bg-light rounded-4 shadow-sm">
                    <div class="display-1 text-muted mb-3">
                        <i class="bi bi-chat-square-dots"></i>
                    </div>
                    <h3 class="text-dark fw-bold">No reviews yet!</h3>
                    <p class="text-muted">Be the first to rent this car and share your experience.</p>
                    <a asp-controller="Cars" asp-action="Index" class="btn btn-primary rounded-pill px-4">Browse More Cars</a>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var review in Model)
                    {
                        <div class="col-12">
                            <div class="card border-0 shadow-sm rounded-4 hover-shadow transition">
                                <div class="card-body p-4">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <div class="d-flex align-items-center">
                                            @* صورة اليوزر اللي قيم *@
                                            <img src="@(string.IsNullOrEmpty(review.User?.ProfileImageUrl) ? "/images/profiles/default.png" : "/images/profiles/" + review.User.ProfileImageUrl)" 
                                                 class="rounded-circle me-3 border" 
                                                 style="width: 50px; height: 50px; object-fit: cover;" alt="User" />
                                            <div>
                                                <h6 class="fw-bold mb-0">@review.User?.FullName</h6>
                                                <small class="text-muted">@review.CreatedAt.ToString("MMM dd, yyyy")</small>
                                            </div>
                                        </div>
                                        @* النجوم *@
                                        <div class="text-warning">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="bi bi-star@(i <= review.Rating ? "-fill" : "")"></i>
                                            }
                                        </div>
                                    </div>
                                    <p class="card-text fs-5 text-dark italic lh-base">
                                        <i class="bi bi-quote fs-2 text-primary opacity-25 me-1"></i>
                                        @review.Comment
                                    </p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<style>
    .rounded-4 { border-radius: 1.2rem !important; }
    .hover-shadow:hover { transform: translateY(-3px); box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.1) !important; }
    .transition { transition: all 0.3s ease; }
    .italic { font-style: italic; }
</style>