@model IEnumerable<Peer_Car.Application.ViewModels.ReviewViewModel>

@{
    ViewData["Title"] = "Review List";
}

<div class="hero-section position-relative mb-5 bg-dark text-white py-5 shadow-sm" style="border-radius: 0 0 2.5rem 2.5rem;">
    <div class="container position-relative text-center py-4">
        <h1 class="display-3 fw-bold mb-2 animate__animated animate__fadeInDown">Community Feedback</h1>
        <p class="lead fs-4 animate__animated animate__fadeInUp opacity-75">What our users say about their journey</p>
        <div class="mt-4">
            <a asp-action="Create" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold shadow-lg">
                <i class="bi bi-plus-circle me-2"></i>Write a Review
            </a>
        </div>
    </div>
</div>

<div class="container mb-5">
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="p-5 bg-light rounded-4 border border-dashed">
                <i class="bi bi-chat-square-dots display-1 text-muted opacity-25 d-block mb-3"></i>
                <h4 class="fw-bold text-muted">No reviews available at the moment.</h4>
                <p class="text-secondary">Be the first to share your experience!</p>
            </div>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 g-4">
            @foreach (var review in Model)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm rounded-4 review-card">
                        <div class="card-header bg-white border-0 pt-4 px-4 pb-0 d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center">
                                <div class="avatar-sm bg-primary-subtle text-primary rounded-circle me-2 fw-bold d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                    @(review.ReviewerName?.Substring(0, 1).ToUpper() ?? "U")
                                </div>
                                <div>
                                    <span class="fw-bold text-dark d-block">@review.ReviewerName</span>
                                    <small class="text-muted x-small">Verified Member</small>
                                </div>
                            </div>
                            <span class="text-muted small"><i class="bi bi-calendar3 me-1"></i> @review.FormattedDate</span>
                        </div>

                        <div class="card-body px-4 py-3">
                            <div class="d-flex align-items-center mb-3 p-3 bg-light rounded-3 border-start border-4 border-primary">
                                @if (!string.IsNullOrEmpty(review.CarImagePath))
                                {
                                    <img src="@Url.Content(review.CarImagePath)" alt="Car" class="rounded shadow-sm me-3" style="width: 85px; height: 60px; object-fit: cover;" />
                                }
                                <div>
                                    <h6 class="mb-1 fw-bold">
                                        <span class="badge rounded-pill bg-primary px-3">@review.TargetName</span>
                                    </h6>
                                    <div class="text-muted small" style="font-size: 0.75rem;">
                                        @if (!string.IsNullOrEmpty(review.CarOwnerName))
                                        {
                                            <span><i class="bi bi-person me-1"></i>Owner: @review.CarOwnerName</span>
                                        }
                                        else if (!string.IsNullOrEmpty(review.CarOwnerEmail))
                                        {
                                            <span><i class="bi bi-envelope me-1"></i>Owner: @review.CarOwnerEmail</span>
                                        }
                                    </div>
                                </div>
                            </div>

                            <p class="card-text text-muted" style="font-size: 0.95rem; line-height: 1.6;">
                                <i class="bi bi-quote fs-4 text-primary opacity-25"></i>
                                @if (review.Comment.Length > 150)
                                {
                                    @(review.Comment.Substring(0, 147) + "...")
                                }
                                else
                                {
                                    @review.Comment
                                }
                            </p>
                        </div>

                        <div class="card-footer bg-white border-0 px-4 pb-4 mt-auto">
                            <div class="d-flex justify-content-between gap-2">
                                <a asp-action="Details" asp-route-id="@review.Id" class="btn btn-outline-primary btn-sm rounded-pill flex-grow-1 fw-bold py-2">
                                    <i class="bi bi-eye me-1"></i> Read full details
                                </a>
                                @if (review.TargetId != Guid.Empty)
                                {
                                    <a asp-controller="Cars" asp-action="Details" asp-route-id="@review.TargetId" class="btn btn-light btn-sm rounded-pill flex-grow-1 fw-bold py-2">
                                        <i class="bi bi-car-front me-1"></i> View Car
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Animate cards on load (Smooth fade-in)
            $(".review-card").each(function(index) {
                $(this).delay(150 * index).animate({opacity: 1}, 600);
            });
        });
    </script>
}

<style>
    .rounded-4 { border-radius: 1.25rem !important; }
    .bg-primary-subtle { background-color: #e7f1ff; }
    .x-small { font-size: 0.7rem; }
    
    .review-card {
        transition: all 0.3s ease;
        opacity: 0; /* Starts hidden for the JS animation */
        border: 1px solid rgba(0,0,0,0.02) !important;
    }
    
    .review-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
    }

    .border-dashed { border-style: dashed !important; border-width: 2px !important; }
</style>