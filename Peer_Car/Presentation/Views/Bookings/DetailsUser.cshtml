@using Peer_Car.Domain.Entities
@using Peer_Car.Domain.Enums
@model Booking

@{
    ViewData["Title"] = "Booking Details";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-primary text-white py-3 border-0 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-info-circle me-2"></i>Booking Details</h5>
                    <a asp-action="MyBookings" class="btn btn-sm btn-light text-primary fw-bold">
                        <i class="bi bi-arrow-left me-1"></i> Back
                    </a>
                </div>
                
                <div class="card-body p-4 p-md-5">
                    <div class="row align-items-center mb-4">
                        <div class="col-md-5 mb-3 mb-md-0 text-center">
                            @if (Model.Car != null && !string.IsNullOrEmpty(Model.Car.ImagePath))
                            {
                                <img src="@Model.Car.ImagePath" alt="Car Image" class="img-fluid rounded-4 shadow-sm" style="max-height:250px; width:100%; object-fit:cover;" />
                            }
                            else
                            {
                                <div class="bg-light rounded-4 d-flex align-items-center justify-content-center border" style="height:200px;">
                                    <i class="bi bi-car-front display-1 text-muted"></i>
                                </div>
                            }
                        </div>
                        <div class="col-md-7">
                            <h2 class="fw-bold mb-2">@Model.Car?.Brand @Model.Car?.Model</h2>
                            <p class="text-muted mb-2"><i class="bi bi-calendar3 me-1"></i> Year: @Model.Car?.Year</p>
                            <p class="text-muted mb-2"><i class="bi bi-geo-alt me-1"></i> Location: @Model.Car?.Location</p>
                            <div class="p-3 bg-light rounded-3 mt-3">
                                <span class="d-block small text-muted text-uppercase fw-bold mb-1">Owner Contact</span>
                                <p class="mb-1 fw-bold">@Model.Car?.Owner?.FullName</p>
                                <p class="mb-0 small text-primary">@Model.Car?.Owner?.Email</p>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4">

                    <div class="row">
                        <div class="col-md-12">
                            <h5 class="fw-bold mb-4">Rental Summary</h5>
                            <div class="list-group list-group-flush border rounded-3">
                                <div class="list-group-item d-flex justify-content-between align-items-center py-3">
                                    <span class="text-muted"><i class="bi bi-calendar-event me-2"></i>Dates</span>
                                    <span class="fw-bold">@Model.StartDate.ToString("MMM dd, yyyy") - @Model.EndDate.ToString("MMM dd, yyyy")</span>
                                </div>
                                <div class="list-group-item d-flex justify-content-between align-items-center py-3">
                                    <span class="text-muted"><i class="bi bi-flag me-2"></i>Status</span>
                                    @{
                                        var statusClass = Model.Status switch
                                        {
                                            BookingStatus.Confirmed => "success",
                                            BookingStatus.Pending => "warning",
                                            BookingStatus.Cancelled => "danger",
                                            BookingStatus.Completed => "info",
                                            _ => "secondary"
                                        };
                                    }
                                    <span class="badge rounded-pill bg-@statusClass px-3 py-2">
                                        @Model.Status
                                    </span>
                                </div>
                                <div class="list-group-item d-flex justify-content-between align-items-center py-3 bg-light">
                                    <span class="h5 mb-0 fw-bold">Total Price</span>
                                    <span class="h5 mb-0 fw-bold text-success">@Model.TotalPrice.ToString("N2") SAR</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 text-center">
                        <a asp-action="MyBookings" class="btn btn-outline-secondary btn-lg px-5 rounded-pill">
                            <i class="bi bi-arrow-left me-2"></i>Back to My Bookings
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-4 {
        border-radius: 1.25rem !important;
    }
</style>