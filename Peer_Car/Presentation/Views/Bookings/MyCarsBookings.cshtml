@model IEnumerable<Peer_Car.Domain.Entities.Car>
@using Peer_Car.Domain.Enums

@{
    ViewData["Title"] = "My Cars Bookings";
}

<div class="container my-5">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold"><i class="bi bi-calendar-range me-2 text-primary"></i>Manage My Cars' Bookings</h2>
            <p class="text-muted">Track who is renting your cars and manage the status.</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm rounded-4 p-5 text-center">
            <i class="bi bi-car-front text-muted display-1"></i>
            <h4 class="mt-3 text-muted">You don't have any cars listed yet.</h4>
            <a asp-controller="Cars" asp-action="Submit" class="btn btn-primary mt-3 rounded-pill px-4">List Your Car Now</a>
        </div>
    }
    else
    {
        <div class="accordion shadow-sm rounded-4 overflow-hidden" id="carsAccordion">
            @foreach (var car in Model)
            {
                <div class="accordion-item border-0 border-bottom">
                    <h2 class="accordion-header" id="heading-@car.Id">
                        <button class="accordion-button collapsed py-3 bg-white" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@car.Id">
                            <div class="d-flex align-items-center w-100">
                                <img src="@car.ImagePath" class="rounded-2 me-3" style="width: 60px; height: 40px; object-fit: cover;" />
                                <div>
                                    <span class="fw-bold d-block text-dark">@car.Brand @car.Model</span>
                                    <small class="text-muted">Total Bookings: @car.Bookings.Count()</small>
                                </div>
                                @if(car.Bookings.Any(b => b.Status == BookingStatus.Pending))
                                {
                                    <span class="badge bg-warning text-dark ms-auto me-3 rounded-pill">New Request!</span>
                                }
                            </div>
                        </button>
                    </h2>
                    <div id="collapse-@car.Id" class="accordion-collapse collapse" data-bs-parent="#carsAccordion">
                        <div class="accordion-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover mb-0 align-middle">
                                    <thead class="table-light small">
                                        <tr>
                                            <th class="ps-4">Renter</th>
                                            <th>Period</th>
                                            <th>Total Price</th>
                                            <th>Status</th>
                                            <th class="text-end pe-4">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var booking in car.Bookings.OrderByDescending(b => b.CreatedAt))
                                        {
                                            <tr>
                                                <td class="ps-4">
                                                    <a asp-controller="Account" asp-action="UserProfile" asp-route-id="@booking.RenterId" class="text-decoration-none">
                                                        <div class="fw-bold text-primary" style="cursor: pointer; hover: text-decoration: underline;">
                                                            @booking.Renter?.FullName
                                                        </div>
                                                    </a>
                                                    <div class="small text-muted">@booking.Renter?.PhoneNumber</div>
                                                </td>
                                                <td>
                                                    <div class="small">@booking.StartDate.ToShortDateString()</div>
                                                    <div class="small text-muted">to @booking.EndDate.ToShortDateString()</div>
                                                </td>
                                                <td class="fw-bold text-success">@booking.TotalPrice.ToString("N0") SAR</td>
                                                <td>
                                                    @{
                                                        var badgeColor = booking.Status switch {
                                                            BookingStatus.Confirmed => "success",
                                                            BookingStatus.Pending => "warning text-dark",
                                                            BookingStatus.Cancelled => "danger",
                                                            BookingStatus.Completed => "info",
                                                            _ => "secondary"
                                                        };
                                                    }
                                                    <span class="badge rounded-pill bg-@badgeColor shadow-sm">@booking.Status</span>
                                                </td>
                                                <td class="text-end pe-4">
                                                    <a asp-action="Details" asp-route-id="@booking.Id" class="btn btn-sm btn-dark rounded-pill px-3">
                                                        Manage <i class="bi bi-arrow-right ms-1"></i>
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                        @if (!car.Bookings.Any())
                                        {
                                            <tr>
                                                <td colspan="5" class="text-center py-4 text-muted">No bookings for this car yet.</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .accordion-button:not(.collapsed) { background-color: #f0f7ff; color: #0d6efd; box-shadow: none; }
    .accordion-item { border-radius: 0 !important; }
</style>