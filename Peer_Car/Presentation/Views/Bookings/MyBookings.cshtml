@using Peer_Car.Domain.Entities
@using Peer_Car.Domain.Enums
@model IEnumerable<Booking>

@{
    ViewData["Title"] = "My Bookings";
}

<div class="container my-5">
    <div class="row mb-5">
        <div class="col-12 text-center">
            <h1 class="display-4 fw-bold mb-2">My Bookings</h1>
            <p class="lead text-muted">Manage all your car rental reservations in one place</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card border-0 shadow-lg rounded-4 text-center p-5">
                    <div class="mb-3">
                        <i class="bi bi-calendar-x fs-1 text-muted"></i>
                    </div>
                    <h5 class="mb-3 fw-bold">You don't have any bookings yet</h5>
                    <p class="text-muted mb-4">Start by browsing available cars and make your first reservation today!</p>
                    <a asp-controller="Cars" asp-action="Index" class="btn btn-primary btn-lg px-4 shadow-sm">
                        <i class="bi bi-search me-2"></i>Browse Cars
                    </a>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var booking in Model)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-lg rounded-4 overflow-hidden">
                        <div class="row g-0 h-100">
                            <div class="col-5 bg-light position-relative">
                                @if (booking.Car != null && !string.IsNullOrEmpty(booking.Car.ImagePath))
                                {
                                    <img src="@booking.Car.ImagePath" alt="Car" class="w-100 h-100" style="object-fit:cover; min-height:180px;" />
                                }
                                else
                                {
                                    <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                                        <i class="bi bi-car-front fs-1"></i>
                                    </div>
                                }
                                <div class="position-absolute top-0 start-0 m-2">
                                    @{
                                        var statusClass = booking.Status switch {
                                            BookingStatus.Confirmed => "success",
                                            BookingStatus.Pending => "warning",
                                            BookingStatus.Cancelled => "danger",
                                            BookingStatus.Completed => "info",
                                            _ => "secondary"
                                        };
                                    }
                                    <span class="badge bg-@statusClass shadow-sm px-2 py-1">@booking.Status</span>
                                </div>
                            </div>

                            <div class="col-7">
                                <div class="card-body d-flex flex-column h-100 p-3">
                                    <h6 class="fw-bold mb-1 text-truncate">@booking.Car?.Brand @booking.Car?.Model</h6>
                                    <small class="text-muted mb-2"><i class="bi bi-geo-alt me-1"></i>@booking.Car?.Location</small>
                                    
                                    <div class="mb-3">
                                        <div class="small fw-bold text-dark">
                                            <i class="bi bi-calendar-event me-1"></i> @booking.StartDate.ToString("MMM dd") - @booking.EndDate.ToString("MMM dd")
                                        </div>
                                        <div class="text-success fw-bold fs-5 mt-1">@booking.TotalPrice.ToString("N0") <small class="fs-6">SAR</small></div>
                                    </div>

                                    <div class="mt-auto pt-2 border-top">
                                        <div class="d-grid gap-2">
                                            <a asp-action="Details" asp-route-id="@booking.Id" class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-info-circle"></i> Details
                                            </a>
                                            
                                            @if (booking.Status == BookingStatus.Pending)
                                            {
                                                <form asp-action="CancelBooking" method="post" onsubmit="return confirm('Are you sure?')">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="bookingId" value="@booking.Id" />
                                                    <button type="submit" class="btn btn-sm btn-link text-danger w-100 p-0 text-decoration-none">
                                                        <i class="bi bi-x-circle"></i> Cancel
                                                    </button>
                                                </form>
                                            }
                                            @if (booking.Status == BookingStatus.Completed)
                                              {
                                                <a asp-controller="Reviews" 
                                                                        asp-action="Create" 
                                                                    asp-route-bookingId="@booking.Id" 
                                                               class="btn btn-sm btn-success shadow-sm">
                                                           <i class="bi bi-star-fill me-1"></i> Rate Now
                                                 </a>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="row mt-5">
        <div class="col-12 text-center">
            <a asp-controller="Cars" asp-action="Index" class="btn btn-outline-dark rounded-pill px-4">
                <i class="bi bi-plus-lg me-2"></i>Book Another Car
            </a>
        </div>
    </div>
</div>

<style>
    .rounded-4 { border-radius: 1.2rem !important; }
    .card:hover { transform: translateY(-5px); transition: 0.3s; }
</style>