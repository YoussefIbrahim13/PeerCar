@{
    ViewData["Title"] = "Update Profile Picture";
}

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-primary py-2"></div>
                
                <div class="card-body p-4 p-md-5 text-center">
                    <div class="mb-4">
                        <h2 class="fw-bold mb-2">Profile Picture</h2>
                        <p class="text-muted small">Choose a photo that represents you clearly on the platform.</p>
                    </div>

                    <div class="mb-4 position-relative d-inline-block">
                        <div id="imagePreviewContainer" class="rounded-circle border border-4 border-white shadow-sm overflow-hidden bg-light" style="width: 160px; height: 160px;">
                            <img id="imagePreview" src="/images/profiles/default.png" class="w-100 h-100" style="object-fit: cover;" alt="Preview" />
                        </div>
                        <div class="position-absolute bottom-0 end-0">
                            <label for="profileImage" class="btn btn-primary btn-sm rounded-circle shadow">
                                <i class="bi bi-camera-fill"></i>
                            </label>
                        </div>
                    </div>

                    <form asp-controller="Users" asp-action="UploadProfilePicture" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        
                        <div class="mb-4">
                            <input type="file" class="form-control d-none" id="profileImage" name="profileImage" accept="image/*" required onchange="displayPreview(this)" />
                            
                            @if (ViewBag.UploadError != null)
                            {
                                <div class="alert alert-danger py-2 small mb-3">
                                    <i class="bi bi-exclamation-circle me-1"></i> @ViewBag.UploadError
                                </div>
                            }
                            
                            <div class="text-muted small mb-3" id="fileNameDisplay">No file selected</div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm">
                                <i class="bi bi-cloud-arrow-up me-2"></i>Upload Now
                            </button>
                            <a asp-action="MyAccount" class="btn btn-link text-muted text-decoration-none small">
                                Cancel and Go Back
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <div class="text-center mt-4">
                <p class="text-muted small">
                    <i class="bi bi-info-circle me-1"></i> 
                    Supported formats: JPG, PNG. Max size: 2MB.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function displayPreview(input) {
            const fileNameDisplay = document.getElementById('fileNameDisplay');
            const preview = document.getElementById('imagePreview');
            
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                
                // Update file name
                fileNameDisplay.textContent = input.files[0].name;
                
                reader.onload = function(e) {
                    preview.src = e.target.result;
                }
                
                reader.readAsDataURL(input.files[0]);
            } else {
                fileNameDisplay.textContent = "No file selected";
                preview.src = "/images/profiles/default.png";
            }
        }
    </script>
}

<style>
    .rounded-4 { border-radius: 1.5rem !important; }
    .card { transition: transform 0.3s ease; }
    #imagePreviewContainer {
        transition: all 0.3s ease;
        border: 4px solid #fff !important;
    }
</style>