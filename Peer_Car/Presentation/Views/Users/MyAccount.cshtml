@using Peer_Car.Domain.Entities
@using Peer_Car.Domain.Enums
@model User

@{
    ViewData["Title"] = "My Account";
}

<div class="container py-5 mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="bg-primary py-2"></div>
                
                <div class="card-body p-4 p-md-5 text-center">
                    <div class="mb-4 position-relative d-inline-block">
                        <img src="@(string.IsNullOrEmpty(Model.ProfileImageUrl) ? "/images/profiles/default.png" : Model.ProfileImageUrl)" 
                             class="rounded-circle shadow-sm border border-4 border-white img-thumbnail" 
                             style="width: 180px; height: 180px; object-fit: cover; cursor: pointer;" 
                             alt="Profile Picture" 
                             data-bs-toggle="modal" data-bs-target="#profileImageModal" />
                        
                        <div class="position-absolute bottom-0 end-0 mb-2 me-2">
                             <a asp-action="EditProfile" class="btn btn-sm btn-primary rounded-circle shadow">
                                 <i class="bi bi-camera"></i>
                             </a>
                        </div>
                    </div>

                    <div class="modal fade" id="profileImageModal" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content bg-transparent border-0">
                                <div class="modal-body p-0">
                                    <img src="@(string.IsNullOrEmpty(Model.ProfileImageUrl) ? "/images/profiles/default.png" : Model.ProfileImageUrl)" 
                                         class="img-fluid rounded-4 shadow-lg w-100" style="background:#fff;" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <h2 class="fw-bold mb-1">@Model.FullName</h2>
                    <div class="mb-4">
                        <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill fw-bold">
                            <i class="bi bi-shield-check me-1"></i> @Model.Role
                        </span>
                    </div>

                    <div class="list-group list-group-flush border rounded-3 mb-4 text-start shadow-sm">
                        <div class="list-group-item d-flex align-items-center py-3">
                            <i class="bi bi-envelope-at text-primary fs-5 me-3"></i>
                            <div>
                                <small class="text-muted d-block">Email Address</small>
                                <span class="fw-semibold">@Model.Email</span>
                            </div>
                        </div>
                        <div class="list-group-item d-flex align-items-center py-3">
                            <i class="bi bi-telephone text-primary fs-5 me-3"></i>
                            <div>
                                <small class="text-muted d-block">Phone Number</small>
                                <span class="fw-semibold">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "Not Provided" : Model.PhoneNumber)</span>
                            </div>
                        </div>
                    </div>

                    <div class="d-grid gap-3">
                        <div class="row g-2">
                            <div class="col-md-6">
                                <a asp-action="EditProfile" class="btn btn-warning btn-lg w-100 rounded-pill fw-bold shadow-sm">
                                    <i class="bi bi-pencil-square me-2"></i>Edit Profile
                                </a>
                            </div>
                            <div class="col-md-6">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-lg w-100 rounded-pill fw-bold">
                                        <i class="bi bi-box-arrow-right me-2"></i>Logout
                                    </button>
                                </form>
                            </div>
                        </div>
                        
                        <hr class="my-3">

                        <a asp-action="RequestDeleteAccount" class="btn btn-link text-danger text-decoration-none small">
                            <i class="bi bi-trash me-1"></i> Delete My Account
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-4 { border-radius: 1.5rem !important; }
    .bg-primary-subtle { background-color: #e7f1ff; }
    .list-group-item { border-color: #f1f1f1; }
</style>