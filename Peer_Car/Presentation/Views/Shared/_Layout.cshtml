@using Microsoft.AspNetCore.Identity
@using Peer_Car.Domain.Entities
@inject UserManager<User> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PeerCar</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Peer_Car.Presentation.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm py-3">
            <div class="container">
                <a class="navbar-brand fw-bold text-primary" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-car-front me-2"></i>PeerCar
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav">
                        <li class="nav-item mx-2">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i> Home
                            </a>
                        </li>
                        <li class="nav-item mx-2">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Cars" asp-action="Index">
                                <i class="bi bi-car-front-fill me-1"></i> Cars
                            </a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item mx-2">
                                <a class="nav-link text-primary fw-bold" asp-area="" asp-controller="Chatbot" asp-action="Index">
                                    <i class="bi bi-robot me-1"></i> AI Assistant
                                </a>
                            </li>
                        }

                        @if (User.Identity?.IsAuthenticated == true && !User.IsInRole("Admin"))
                        {
                            <li class="nav-item mx-2">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Cars" asp-action="Submit">
                                    <i class="bi bi-plus-circle me-1"></i> Submit Car
                                </a>
                            </li>
                            <li class="nav-item mx-2">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Cars" asp-action="MyCars">
                                    <i class="bi bi-car-front me-1"></i> My Cars
                                </a>
                            </li>
                            <li class="nav-item mx-2">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Bookings" asp-action="MyCarsBookings">
                                    <i class="bi bi-calendar-range me-1"></i> Cars Bookings
                                </a>
                            </li>
                        }

                        <li class="nav-item mx-2">
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-area="" asp-controller="Admin" asp-action="UserReservations" class="nav-link">
                                    <i class="bi bi-people me-1"></i> User Reservations
                                </a>
                            }
                            else if (User.Identity?.IsAuthenticated == true)
                            {
                                <a asp-area="" asp-controller="Bookings" asp-action="MyBookings" class="nav-link">
                                    <i class="bi bi-calendar-check me-1"></i> My Bookings
                                </a>
                            }
                        </li>

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown mx-2">
                                <a class="nav-link dropdown-toggle text-dark" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-gear-fill me-1"></i> Admin
                                </a>
                                <ul class="dropdown-menu shadow-sm border-0" aria-labelledby="adminDropdown">
                                    <li><a class="dropdown-item py-2" asp-controller="Admin" asp-action="Dashboard"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a></li>
                                    <li><a class="dropdown-item py-2" asp-controller="Admin" asp-action="Users"><i class="bi bi-people me-2"></i>Users</a></li>
                                    <li><a class="dropdown-item py-2" asp-controller="Admin" asp-action="Cars"><i class="bi bi-car-front me-2"></i>Cars</a></li>
                                    <li><a class="dropdown-item py-2" asp-controller="Admin" asp-action="Bookings"><i class="bi bi-calendar2-check me-2"></i>Bookings</a></li>
                                    <li><a class="dropdown-item py-2" asp-controller="Admin" asp-action="PendingVerifications"><i class="bi bi-shield-check me-2 text-success"></i>User Verifications</a></li>
                                    <li><a class="dropdown-item py-2" asp-controller="Admin" asp-action="CarSubmissions"><i class="bi bi-file-earmark-check me-2"></i>Car Submissions</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item py-2" asp-controller="Admin" asp-action="Archive"><i class="bi bi-archive me-2 text-danger"></i>System Archive</a></li>
                                </ul>
                            </li>
                        }
                    </ul>

                    <div class="d-flex align-items-center">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            var userObj = await UserManager.GetUserAsync(User);
                            string displayName = userObj?.FirstName ?? User.Identity.Name ?? "User";

                            string profileImg = string.IsNullOrEmpty(userObj?.ProfileImageUrl) || userObj.ProfileImageUrl == "default.png"
                                                ? "/images/profiles/default.png"
                                                : "/images/profiles/" + userObj.ProfileImageUrl;

                            <div class="dropdown">
                                <button class="btn btn-outline-primary dropdown-toggle d-flex align-items-center rounded-pill px-3" type="button" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                    <img src="@profileImg"
                                         class="rounded-circle me-2"
                                         style="width:30px; height:30px; object-fit:cover;"
                                         alt="Profile"
                                         onerror="this.onerror=null;this.src='/images/profiles/default.png';" />
                                    @displayName
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="userDropdown">
                                    @if (!User.IsInRole("Admin"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="Bookings" asp-action="MyBookings"><i class="bi bi-calendar-check me-2"></i>My Bookings</a></li>
                                    }
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="MyAccount"><i class="bi bi-person-lines-fill me-2"></i>My Account</a></li>
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="EditProfile"><i class="bi bi-pencil-square me-2"></i>Edit Profile</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="px-3">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-link text-danger p-0 text-decoration-none w-100 text-start">
                                                <i class="bi bi-box-arrow-right me-2"></i>Logout
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary me-2 rounded-pill px-4">
                                <i class="bi bi-box-arrow-in-right me-1"></i> Login
                            </a>
                            <a asp-controller="Account" asp-action="Register" class="btn btn-primary rounded-pill px-4 shadow-sm">
                                <i class="bi bi-person-plus me-1"></i> Register
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        <main role="main" class="pb-5">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["InfoMessage"] != null)
            {
                <div class="alert alert-info alert-dismissible fade show rounded-3 shadow-sm" role="alert">
                    <i class="bi bi-info-circle-fill me-2"></i>@TempData["InfoMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted border-top py-3 mt-auto bg-light">
        <div class="container text-center">
            &copy; @DateTime.Now.Year - <span class="fw-bold text-primary">PeerCar</span> - Your Trusted Peer-to-Peer Rental
        </div>
    </footer>
    @* @if (ViewData["HideFooter"] == null)
    {
        <footer class="footer text-muted border-top py-3 mt-auto bg-light">
            <div class="container text-center">
                &copy; @DateTime.Now.Year - <span class="fw-bold text-primary">PeerCar</span> - Your Trusted Peer-to-Peer Rental
            </div>
        </footer>
    } *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>