@using Peer_Car.Domain.Entities
@model IEnumerable<Car>

@if (!Model.Any())
{
    <div class="col-12 text-center py-5">
        <div class="text-muted">
            <i class="bi bi-car-front fs-1 d-block mb-3 opacity-25"></i>
            <p class="fs-5">No cars available at the moment.</p>
        </div>
    </div>
}
else
{
    @foreach (var car in Model)
    {
        <div class="col-12 col-md-6 col-lg-4 mb-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden card-hover">
                <div class="position-relative">
                    @if (!string.IsNullOrEmpty(car.ImagePath))
                    {
                        <img src="@car.ImagePath" alt="@car.Brand" class="card-img-top" style="height:220px; object-fit:cover;" />
                    }
                    else
                    {
                        <div class="bg-light d-flex align-items-center justify-content-center" style="height:220px;">
                            <i class="bi bi-image text-muted fs-1"></i>
                        </div>
                    }
                    <div class="position-absolute bottom-0 end-0 m-3">
                        <span class="badge bg-dark rounded-pill px-3 py-2 shadow">
                            <span class="fw-bold">@car.PricePerDay.ToString("N0")</span> <small>SAR/Day</small>
                        </span>
                    </div>
                </div>

                <div class="card-body p-4">
                    <h5 class="card-title fw-bold text-dark mb-1">@car.Brand @car.Model</h5>
                    <p class="text-muted small mb-3"><i class="bi bi-geo-alt me-1"></i>@car.Location</p>
                    
                    <div class="d-flex justify-content-between align-items-center mt-auto">
                        <div class="small text-secondary">
                            <i class="bi bi-calendar3 me-1"></i> @car.Year
                        </div>
                        <div class="d-flex gap-2">
                            <a asp-controller="Cars" asp-action="Details" asp-route-id="@car.Id" class="btn btn-primary btn-sm rounded-pill px-3">
                                View Details
                            </a>
                            
                            @if (User.IsInRole("Admin"))
                            {
                                <div class="dropdown">
                                    <button class="btn btn-outline-secondary btn-sm rounded-circle" type="button" data-bs-toggle="dropdown">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3">
                                        <li>
                                            <a asp-controller="Cars" asp-action="Edit" asp-route-id="@car.Id" class="dropdown-item text-warning">
                                                <i class="bi bi-pencil-square me-2"></i>Edit
                                            </a>
                                        </li>
                                        <li>
                                            <form asp-controller="Cars" asp-action="Delete" asp-route-id="@car.Id" method="post" onsubmit="return confirm('Are you sure?')">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="dropdown-item text-danger">
                                                    <i class="bi bi-trash me-2"></i>Delete
                                                </button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
}

<style>
    .rounded-4 { border-radius: 1.25rem !important; }
    .card-hover { transition: transform 0.3s ease, box-shadow 0.3s ease; }
    .card-hover:hover { transform: translateY(-5px); box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important; }
</style>