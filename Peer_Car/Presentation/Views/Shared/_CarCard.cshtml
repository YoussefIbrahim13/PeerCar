@model Peer_Car.Application.ViewModels.CarViewModel

<div class="col-md-4 mb-4">
    <div class="card h-100 shadow-sm border-0">
        @if (!string.IsNullOrEmpty(Model.ImagePath))
        {
            <img src="@Model.ImagePath" class="card-img-top" style="height: 200px; object-fit: cover;" alt="@Model.Brand @Model.Model">
        }
        else
        {
            <div class="bg-light text-center py-5">
                <i class="bi bi-car-front text-secondary" style="font-size: 3rem;"></i>
            </div>
        }
        <div class="card-body">
            <h5 class="card-title fw-bold">@Model.Brand @Model.Model</h5>
            <p class="card-text text-muted">
                <i class="bi bi-geo-alt me-1"></i>@Model.Location
            </p>
            <div class="d-flex justify-content-between align-items-center mt-3">
                <span class="text-primary fw-bold">@Model.PricePerDay SAR/day</span>
                <a asp-controller="Cars" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-primary">
                    Details
                </a>
            </div>
        </div>
    </div>
</div>