@model IEnumerable<Peer_Car.Application.ViewModels.CarViewModel>

@foreach (var car in Model)
{
    <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden">
            <img src="@car.ImagePath" class="card-img-top" alt="@car.Brand" style="height: 200px; object-fit: cover;">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 class="fw-bold mb-0">@car.Brand @car.Model</h5>
                    <span class="badge bg-primary rounded-pill">@car.Year</span>
                </div>
                <p class="text-muted small mb-3"><i class="bi bi-geo-alt me-1"></i>@car.Location</p>
                <div class="d-flex justify-content-between align-items-center">
                    <div class="h5 fw-bold text-primary mb-0">$@car.PricePerDay<small class="text-muted fw-normal">/day</small></div>
                    <a asp-controller="Cars" asp-action="Details" asp-route-id="@car.Id" class="btn btn-outline-dark rounded-pill px-4">Details</a>
                </div>
            </div>
        </div>
    </div>
}