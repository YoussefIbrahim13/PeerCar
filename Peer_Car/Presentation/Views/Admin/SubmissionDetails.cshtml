@using Peer_Car.Application.ViewModels
@using Peer_Car.Domain.Enums
@model CarSubmissionViewModel

@{
    ViewData["Title"] = "Submission Review";
}

<div class="container mt-5 mb-5">
    @* الهيدر: يرجعك لقائمة الطلبات اللي لسه متوافقتش *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">Submission Review</h2>
        <a asp-controller="Admin" asp-action="CarSubmissions" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to Requests
        </a>
    </div>

    <div class="row">
        @* كارت بيانات المالك *@
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-header bg-primary text-white py-3 rounded-top-4">
                    <h5 class="mb-0">Owner Info</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="text-muted small d-block">Submitted By</label>
                        <span class="fw-bold">@Model.SubmittedByName</span>
                    </div>
                    <div class="mb-3">
                        <label class="text-muted small d-block">Email</label>
                        <span class="fw-bold">@Model.SubmittedByEmail</span>
                    </div>
                    <div class="mb-0">
                        <label class="text-muted small d-block">Submission Date</label>
                        <span class="fw-bold">@Model.SubmissionDate.ToString("MMM dd, yyyy")</span>
                    </div>
                </div>
            </div>
        </div>

        @* تفاصيل العربية *@
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div>
                            <h3 class="fw-bold mb-1">@Model.CarBrand @Model.CarModel</h3>
                            <span class="badge bg-info text-dark">Submission ID: @Model.Id.ToString().Substring(0, 8).ToUpper()</span>
                        </div>
                        <div class="text-end">
                            @{
                                var statusColor = Model.Status == CarSubmissionStatus.Pending ? "warning" :
                                                 Model.Status == CarSubmissionStatus.Approved ? "success" : "danger";
                            }
                            <span class="badge p-2 px-3 bg-@statusColor">
                                Status: @Model.Status
                            </span>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            @if (!string.IsNullOrEmpty(Model.CarImagePath))
                            {
                                <img src="@Model.CarImagePath" class="img-fluid rounded-3 shadow-sm border" alt="Car" style="width:100%; height:250px; object-fit:cover;" />
                            }
                        </div>
                        <div class="col-md-6 mt-3 mt-md-0">
                            <h5 class="fw-bold border-bottom pb-2">Specifications</h5>
                            <ul class="list-unstyled">
                                <li class="mb-2"><i class="bi bi-calendar3 me-2 text-primary"></i> <strong>Year:</strong> @Model.CarYear</li>
                                <li class="mb-2"><i class="bi bi-tag me-2 text-primary"></i> <strong>Price/Day:</strong> @Model.CarPricePerDay.ToString("N2") SAR</li>
                                <li class="mb-2"><i class="bi bi-info-circle me-2 text-primary"></i> <strong>Description:</strong> @Model.CarDescription</li>
                            </ul>

                            @* 📄 هنا تعديل فتح المستندات القانونية *@
                            @if (!string.IsNullOrEmpty(Model.CarDocumentPath))
                            {
                                <div class="mt-4">
                                    <a href="@Model.CarDocumentPath" target="_blank" class="btn btn-outline-dark w-100">
                                        <i class="bi bi-file-earmark-pdf me-2"></i> View Legal Documents
                                    </a>
                                </div>
                            }
                            else
                            {
                                <div class="mt-4">
                                    <button class="btn btn-outline-secondary w-100" disabled>
                                        <i class="bi bi-file-earmark-x me-2"></i> No Documents Provided
                                    </button>
                                </div>
                            }
                        </div>
                    </div>

                    <hr class="my-4">

                    @* 🛠️ زراير التحكم (الموافقة والرفض) *@
                    @if (Model.Status == CarSubmissionStatus.Pending)
                    {
                        <div class="d-flex gap-2">
                            @* فورمة الموافقة: موجهة لـ Admin/ApproveSubmission *@
                            <form asp-controller="Admin" asp-action="ApproveSubmission" asp-route-id="@Model.Id" method="post" class="flex-grow-1">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-success btn-lg w-100 shadow-sm">
                                    <i class="bi bi-check-circle me-2"></i> Approve & Go to Inventory
                                </button>
                            </form>
                            
                            <button class="btn btn-danger btn-lg flex-grow-1 shadow-sm" data-bs-toggle="modal" data-bs-target="#rejectModal">
                                <i class="bi bi-x-circle me-2"></i> Reject
                            </button>
                        </div>
                    }

                    @if (Model.Status == CarSubmissionStatus.Rejected && !string.IsNullOrEmpty(Model.RejectionReason))
                    {
                        <div class="alert alert-danger border-0 shadow-sm mt-3">
                            <h6 class="fw-bold"><i class="bi bi-exclamation-triangle me-2"></i> Rejection Reason:</h6>
                            <p class="mb-0">@Model.RejectionReason</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@* مودال الرفض (تم تحديث المسار ليكون Admin/RejectSubmission) *@
<div class="modal fade" id="rejectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <form asp-controller="Admin" asp-action="RejectSubmission" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header bg-danger text-white border-0">
                    <h5 class="modal-title fw-bold">Confirm Rejection</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label for="reason" class="form-label fw-bold">Reason for rejection</label>
                        <textarea name="reason" id="reason" class="form-control" rows="4" required placeholder="Please explain why..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light" data-bs-modal="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger px-4">Confirm Reject</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('show.bs.modal', function (event) {
            var zIndex = 1040 + (10 * document.querySelectorAll('.modal.show').length);
            event.target.style.zIndex = zIndex;
            setTimeout(function () {
                var modalBackdrop = document.querySelector('.modal-backdrop:not(.modal-stack)');
                if (modalBackdrop) {
                    modalBackdrop.style.zIndex = zIndex - 1;
                    modalBackdrop.classList.add('modal-stack');
                }
            }, 0);
        });
    </script>
}