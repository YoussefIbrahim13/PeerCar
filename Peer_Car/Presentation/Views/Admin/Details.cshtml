@using Peer_Car.Domain.Entities

@using Peer_Car.Domain.Enums

@model Booking



@{

    ViewData["Title"] = "Admin: Booking Details";
}
<div class="hero-section position-relative mb-5 bg-dark text-white py-5 shadow-sm">

    <div class="container position-relative text-center">

        <h1 class="display-4 fw-bold mb-2 animate__animated animate__fadeInDown">Management: Booking Details</h1>

        <p class="lead mb-0 animate__animated animate__fadeInUp text-info">Internal Reference: #@Model.Id</p>

    </div>
</div>
<div class="container mb-5">

    <div class="row">

        <div class="col-lg-10 mx-auto">

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                <div class="card-body p-4 p-md-5">


                    <div class="d-flex justify-content-between align-items-center mb-5 border-bottom pb-4">

                        <div>

                            <h4 class="fw-bold mb-1">Reservation Overview</h4>

                            <p class="text-muted small mb-0">Manage and verify booking status</p>

                        </div>

                        <div class="text-end">

                            @{

                                var statusClass = Model.Status switch
                                {

                                    BookingStatus.Confirmed => "success",

                                    BookingStatus.Pending => "warning text-dark",

                                    BookingStatus.Cancelled => "danger",

                                    BookingStatus.Completed => "info",

                                    _ => "secondary"

                                };

                            }

                            <span class="badge rounded-pill bg-@statusClass px-4 py-2 fs-6 shadow-sm">

                                @Model.Status

                            </span>

                        </div>

                    </div>


                    <div class="row g-5">

                        <div class="col-md-6">

                            <div class="mb-4">

                                <h5 class="fw-bold text-uppercase small text-primary mb-3"><i class="bi bi-car-front me-2"></i>Car Information</h5>

                                <div class="p-3 bg-light rounded-3 border-start border-4 border-primary">

                                    <h6 class="fw-bold mb-1">@Model.Car?.Brand @Model.Car?.Model</h6>

                                    <p class="text-muted mb-0 small">Daily Rate: @Model.Car?.PricePerDay.ToString("N2") SAR</p>

                                    <p class="text-muted mb-0 small">Location: @Model.Car?.Location</p>

                                </div>

                            </div>


                            <div class="mb-4">

                                <h5 class="fw-bold text-uppercase small text-info mb-3"><i class="bi bi-person-badge me-2"></i>Renter Information</h5>

                                <div class="d-flex align-items-center p-3 border rounded-3">

                                    <div class="avatar-circle me-3 bg-info text-white shadow-sm">

                                        @(Model.Renter?.FullName?.Substring(0, 1).ToUpper() ?? "?")

                                    </div>

                                    <div>

                                        <p class="mb-0 fw-bold">@Model.Renter?.FullName</p>

                                        <p class="mb-0 small text-muted">@Model.Renter?.Email</p>

                                    </div>

                                </div>

                            </div>

                        </div>


                        <div class="col-md-6">

                            <div class="mb-4">

                                <h5 class="fw-bold text-uppercase small text-secondary mb-3"><i class="bi bi-calendar-check me-2"></i>Booking Period</h5>

                                <div class="list-group list-group-flush small border rounded-3">

                                    <div class="list-group-item d-flex justify-content-between">

                                        <span class="text-muted">Start Date:</span>

                                        <span class="fw-bold">@Model.StartDate.ToString("MMM dd, yyyy")</span>

                                    </div>

                                    <div class="list-group-item d-flex justify-content-between">

                                        <span class="text-muted">End Date:</span>

                                        <span class="fw-bold">@Model.EndDate.ToString("MMM dd, yyyy")</span>

                                    </div>

                                    <div class="list-group-item d-flex justify-content-between bg-light">

                                        <span class="text-muted">Duration:</span>

                                        <span class="fw-bold">@((Model.EndDate - Model.StartDate).Days + 1) days</span>

                                    </div>

                                </div>

                            </div>


                            <div class="mb-4">

                                <h5 class="fw-bold text-uppercase small text-success mb-3"><i class="bi bi-credit-card me-2"></i>Financials</h5>

                                <div class="p-3 bg-success-subtle rounded-3 border border-success border-opacity-25">

                                    <div class="d-flex justify-content-between align-items-center">

                                        <span class="fw-bold">Total Price:</span>

                                        <span class="h4 fw-bold text-success mb-0">@Model.TotalPrice.ToString("N2") <small class="fs-6">SAR</small></span>

                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>


                    <div class="alert @(Model.RefundAmount.HasValue && Model.RefundAmount > 0 ? "alert-warning" : "alert-light") border-0 shadow-sm mb-5 p-4 rounded-4">

                        <h5 class="fw-bold mb-3"><i class="bi bi-cash-stack me-2"></i>Refund Management</h5>

                        @if (Model.RefundAmount.HasValue && Model.RefundAmount.Value > 0 && Model.IsCarReturnedByUser)

                        {

                            <div class="d-flex align-items-center justify-content-between">

                                <div>

                                    <p class="mb-1">Potential Refund for early return: <strong class="text-danger">@Model.RefundAmount.Value.ToString("N2") SAR</strong></p>

                                    @if (Model.IsRefunded)
                                    {

                                        <span class="badge bg-success"><i class="bi bi-patch-check me-1"></i>Refund Processed</span>

                                    }
                                    else
                                    {

                                        <span class="badge bg-danger animate__animated animate__flash animate__infinite">Awaiting Action</span>

                                    }

                                </div>

                                @if (!Model.IsRefunded)

                                {

                                    <form method="post" asp-action="ConfirmRefund" asp-controller="Admin" asp-route-id="@Model.Id">

                                        @Html.AntiForgeryToken()

                                        <button type="submit" class="btn btn-warning fw-bold shadow-sm">Mark as Refunded</button>

                                    </form>

                                }

                            </div>

                        }

                        else

                        {

                            <p class="text-muted mb-0">No pending refunds for this transaction.</p>

                        }

                    </div>


                    <div class="bg-light p-4 rounded-4 border">

                        <h5 class="fw-bold mb-4"><i class="bi bi-shield-lock me-2"></i>Admin Actions</h5>

                        <div class="d-flex flex-wrap gap-3">

                            @if (Model.Status != BookingStatus.Completed && Model.Status != BookingStatus.Cancelled)

                            {

                                <form asp-action="UpdateBookingStatus" asp-controller="Admin" asp-route-id="@Model.Id" asp-route-status="Confirmed" method="post">

                                    <button type="submit" class="btn btn-primary px-4 shadow-sm">Confirm Booking</button>

                                </form>

                                <form asp-action="UpdateBookingStatus" asp-controller="Admin" asp-route-id="@Model.Id" asp-route-status="Completed" method="post">

                                    <button type="submit" class="btn btn-success px-4 shadow-sm">Set as Completed</button>

                                </form>

                                <form asp-action="UpdateBookingStatus" asp-controller="Admin" asp-route-id="@Model.Id" asp-route-status="Cancelled" method="post">

                                    <button type="submit" class="btn btn-outline-danger px-4 shadow-sm" onclick="return confirm('Danger: This will cancel the booking. Proceed?')">Cancel Booking</button>

                                </form>

                            }

                            <a asp-action="Bookings" asp-controller="Admin" class="btn btn-secondary px-4">Back to List</a>

                        </div>

                    </div>



                </div>

            </div>

        </div>

    </div>
</div>
<style>

    .avatar-circle {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 1.2rem;
    }

    .rounded-4 {        border-radius: 1.25rem !important;
    }</style>