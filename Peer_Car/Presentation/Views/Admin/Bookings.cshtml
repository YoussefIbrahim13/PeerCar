@using Peer_Car.Domain.Entities
@using Peer_Car.Domain.Enums
@model IEnumerable<Booking>
@{
    ViewData["Title"] = "Manage Bookings";
    string currentStatus = Context.Request.Query["status"];
}

<div class="hero-section position-relative mb-5">
    <div class="hero-overlay"></div>
    <div class="container position-relative py-5">
        <div class="row">
            <div class="col-lg-8 col-md-10 mx-auto text-center text-white">
                <h1 class="display-3 fw-bold mb-4">Booking Management</h1>
                <p class="lead fs-4 mb-4">Administer all reservations in the platform</p>
            </div>
        </div>
    </div>
</div>

<div class="container mb-5">
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                <h4 class="fw-bold mb-0">All Reservations</h4>
                <div class="btn-group shadow-sm">
                    <a asp-action="Bookings" class="btn btn-sm btn-outline-primary @(string.IsNullOrEmpty(currentStatus) ? "active" : "")">All</a>
                    <a asp-action="Bookings" asp-route-status="Pending" class="btn btn-sm btn-outline-primary @(currentStatus == "Pending" ? "active" : "")">Pending</a>
                    <a asp-action="Bookings" asp-route-status="Confirmed" class="btn btn-sm btn-outline-primary @(currentStatus == "Confirmed" ? "active" : "")">Confirmed</a>
                    <a asp-action="Bookings" asp-route-status="Completed" class="btn btn-sm btn-outline-primary @(currentStatus == "Completed" ? "active" : "")">Completed</a>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Car</th>
                            <th>Renter</th>
                            <th>Period</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var booking in Model)
                        {
                            <tr>
                                <td class="fw-bold">#@booking.Id.ToString().Substring(0,8)</td>
                                <td>@booking.Car?.Brand @booking.Car?.Model</td>
                                <td>@booking.Renter?.FullName</td> @* تعديل لـ FullName *@
                                <td class="small">
                                    @booking.StartDate.ToString("MMM dd") - @booking.EndDate.ToString("MMM dd")
                                </td>
                                <td>
                                    <span class="badge rounded-pill bg-@(booking.Status switch {
                                        BookingStatus.Confirmed => "success",
                                        BookingStatus.Pending => "warning",
                                        BookingStatus.Cancelled => "danger",
                                        _ => "info"
                                    })">@booking.Status</span>
                                </td>
                                <td>
                                    <a asp-action="BookingDetails" asp-route-id="@booking.Id" class="btn btn-sm btn-primary rounded-pill px-3">Details</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>