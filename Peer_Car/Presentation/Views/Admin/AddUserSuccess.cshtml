@{
    ViewData["Title"] = "User Created";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card border-0 shadow-sm p-5 rounded-4">
                <i class="bi bi-check-circle-fill text-success display-1 mb-4"></i>
                <h2 class="fw-bold">User Added Successfully!</h2>
                <p class="text-muted mb-4">The new user account has been created and is now active in the system.</p>
                <div class="d-grid">
                    <a asp-action="Index" class="btn btn-primary btn-lg rounded-pill">
                        <i class="bi bi-people me-2"></i>Back to Users List
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>