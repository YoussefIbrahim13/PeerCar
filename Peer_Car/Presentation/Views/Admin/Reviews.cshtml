@using Peer_Car.Domain.Entities
@model IEnumerable<Review>

@{
    ViewData["Title"] = "Review Moderation";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-star-half me-2 text-warning"></i>Review Moderation</h2>
            <p class="text-muted">Monitor and manage user feedback across the platform.</p>
        </div>
        <div class="text-end">
            <span class="badge bg-dark rounded-pill px-3 py-2">Total Reviews: @Model.Count()</span>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Car</th>
                            <th>Reviewer</th>
                            <th>Comment & Rating</th>
                            <th>Date</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var review in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                @if (review.Car != null)
                                {
                                    <div class="fw-bold">@review.Car.Brand @review.Car.Model</div>
                                    <small class="text-muted">ID: #@review.CarId.ToString().Substring(0, 8)</small>
                                }
                                else
                                {
                                    <span class="text-muted small">Car Deleted</span>
                                }
                            </td>
                            <td>
                                <div class="fw-semibold">@review.User?.FullName</div>
                                <small class="text-muted">@review.User?.Email</small>
                            </td>
                            <td style="max-width: 300px;">
                                <div class="text-warning mb-1">
                                    @* عرض النجوم بناءً على التقييم *@
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="bi bi-star@(i <= review.Rating ? "-fill" : "")"></i>
                                    }
                                </div>
                                <p class="small mb-0 text-truncate" title="@review.Comment">@review.Comment</p>
                            </td>
                            <td>@review.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="text-end pe-4">
                                <form asp-action="DeleteReview" asp-route-id="@review.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this review?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill">
                                        <i class="bi bi-trash me-1"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-4 { border-radius: 1rem !important; }
    .table thead th { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; padding: 1rem 0.5rem; }
</style>