@using Microsoft.AspNetCore.Identity
@using Peer_Car.Application.ViewModels
@using Peer_Car.Domain.Entities
@model IEnumerable<CarViewModel>

@inject UserManager<User> UserManager

@{
    ViewData["Title"] = "Available Cars";
    bool isAdmin = User.IsInRole("Admin");
}

<div class="hero-section position-relative mb-5 bg-dark text-white py-5 shadow-sm" style="background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('/images/hero-bg.jpg') center/cover;">
    <div class="container position-relative py-4">
        <div class="row">
            <div class="col-lg-8 mx-auto text-center">
                <h1 class="display-3 fw-bold mb-3 animate__animated animate__fadeInDown">Available Cars</h1>
                <p class="lead fs-4 mb-4 animate__animated animate__fadeInUp">Find the perfect vehicle for your next journey</p>
                
                <div class="d-flex justify-content-center gap-3 animate__animated animate__fadeInUp">
@if (User.Identity?.IsAuthenticated == true && !isAdmin)
    {
        <a asp-action="Submit" class="btn btn-success btn-lg px-4 shadow">
            <i class="bi bi-car-front me-2"></i>Submit Your Car
        </a>
    }
    else if (User.Identity?.IsAuthenticated != true)
    {
        <a asp-controller="Account" asp-action="Register" class="btn btn-lg btn-outline-light px-5 py-3 rounded-pill fw-bold">
            Join Now
        </a>
    }
</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container mb-5">
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h5 class="fw-bold mb-3"><i class="bi bi-filter-right me-2"></i>Filter Options</h5>
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label small fw-bold">Brand</label>
                    <select class="form-select border-0 bg-light" name="brand">
                        <option value="">All Brands</option>
                        @if (ViewBag.Brands != null)
                        {
                            foreach (var b in (List<string>)ViewBag.Brands)
                            {
                                <option value="@b" selected="@(ViewBag.SelectedBrand == b)">@b</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-bold">Price Range</label>
                    <select class="form-select border-0 bg-light" name="priceRange">
                        <option value="">Any Price</option>
                        @{
                            var priceOptions = new List<(string val, string label)>{
                                    ("0-2000", "Under 2000 SAR"),
                                  ("2000-4000", "2000 - 4000 SAR"),
                                       ("4000-6000", "4000 - 6000 SAR"),
                                               ("6000+", "Above 6000 SAR")
                            };
                            foreach (var opt in priceOptions)
                            {
                                <option value="@opt.val" selected="@(ViewBag.SelectedPriceRange == opt.val)">@opt.label</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100 py-2 shadow-sm">
                        <i class="bi bi-search me-2"></i>Apply Filters
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="container mb-5">
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-search text-muted" style="font-size: 4rem;"></i>
            <h3 class="mt-3 text-muted">No cars found matching your criteria.</h3>
            <a asp-action="Index" class="btn btn-link text-primary">Clear all filters</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                @* استخدمنا الـ Partial View هنا لتقليل تكرار الكود *@
                <partial name="_CarCard" model="item" />
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            console.log("PeerCar Index loaded successfully.");
        });
    </script>
}