@using Microsoft.AspNetCore.Identity
@using Peer_Car.Domain.Entities
@using Peer_Car.Domain.Enums
@model Car

@inject UserManager<User> UserManager

@{
    ViewData["Title"] = $"{Model.Brand} {Model.Model} - Details";
    
    bool isAdmin = User.IsInRole("Admin");
    var currentUserId = UserManager.GetUserId(User);
    bool isOwner = currentUserId != null && Guid.Parse(currentUserId) == Model.OwnerId;
}

<div class="container my-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Cars</a></li>
            <li class="breadcrumb-item active">@Model.Brand @Model.Model</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-11">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="row g-0">
                    <div class="col-md-6 bg-light d-flex align-items-center justify-content-center p-3">
                        @if (!string.IsNullOrEmpty(Model.ImagePath))
                        {
                            <img src="@Model.ImagePath" alt="Car Image" class="img-fluid rounded-4 shadow-sm"
                                 style="width:100%; max-height:450px; object-fit:cover;" />
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <i class="bi bi-image text-muted" style="font-size: 5rem;"></i>
                                <p class="text-muted">No Image Available</p>
                            </div>
                        }
                    </div>

                    <div class="col-md-6 p-4 p-lg-5">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h1 class="fw-bold h2 mb-1">@Model.Brand @Model.Model</h1>
                                <span class="badge bg-primary px-3 py-2">
                                    <i class="bi bi-geo-alt me-1"></i> @Model.Location
                                </span>
                            </div>
                            <div class="text-end">
                                <div class="h3 fw-bold text-success mb-0">@Model.PricePerDay <small class="fs-6 text-muted">SAR/day</small></div>
                                <span class="badge bg-light text-dark border">Year: @Model.Year</span>
                            </div>
                        </div>

                        <hr class="my-4">

                        <div class="mb-4">
                            <h5 class="fw-bold mb-3">Owner Information</h5>
                            <div class="d-flex align-items-center">
                                <div class="flex-shrink-0">
                                    @{
                                        var rawPath = Model.Owner?.ProfileImageUrl;
                                        string finalOwnerPath = "/images/profiles/default.png"; 

                                        if (!string.IsNullOrEmpty(rawPath) && rawPath != "default.png")
                                        {
                                        
                                            var cleanPath = rawPath.Replace("\\", "/").Replace("wwwroot", "").TrimStart('~').TrimStart('/');

                                            if (cleanPath.Contains("images/profiles/"))
                                            {
                                                finalOwnerPath = "/" + cleanPath.Substring(cleanPath.IndexOf("images/"));
                                            }
                                            else
                                            {
                                                finalOwnerPath = "/images/profiles/" + cleanPath;
                                            }
                                        }
                                    }
                                    <img src="@finalOwnerPath"
                                         class="rounded-circle border shadow-sm"
                                         style="width:55px; height:55px; object-fit:cover;"
                                         onerror="this.onerror=null;this.src='/images/profiles/default.png';" />
                                </div>
                                <div class="ms-3">
                                    @if (Model.Owner != null)
                                    {
                                        <a asp-controller="Account" asp-action="UserProfile" asp-route-id="@Model.OwnerId"
                                               class="fw-bold text-decoration-none text-dark d-block">
                                            @Model.Owner.FullName
                                        </a>
                                        <div class="small text-muted">Member since @Model.Owner.DateRegistered.Year</div>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <h5 class="fw-bold mb-2">Availability</h5>
                            @{
                                var statusClass = Model.AvailabilityStatus == CarAvailabilityStatus.Available ? "success" : "danger";
                                var statusText = Model.AvailabilityStatus == CarAvailabilityStatus.Available ? "Ready to Rent" : "Currently Rented";
                            }
                            <span class="badge bg-@statusClass p-2 px-3 fw-medium">
                                <i class="bi bi-info-circle me-1"></i> @statusText
                            </span>
                        </div>

                        <div class="d-grid gap-2 pt-3">
                            @if (Model.AvailabilityStatus == CarAvailabilityStatus.Available && !isAdmin && !isOwner)
                            {
                                <a asp-controller="Bookings" asp-action="Create" asp-route-carId="@Model.Id"
                                       class="btn btn-primary btn-lg fw-bold shadow-sm">
                                    <i class="bi bi-calendar-plus me-2"></i> Book This Car
                                </a>
                            }

                            <a asp-controller="Reviews" asp-action="CarReviews" asp-route-carId="@Model.Id"
                                   class="btn btn-outline-dark">
                                <i class="bi bi-star-fill me-2 text-warning"></i> View All Reviews
                            </a>
                        </div>

                        @if (isAdmin || isOwner)
                        {
                            <div class="mt-4 p-3 bg-light rounded-3 border">
                                <p class="small fw-bold text-muted mb-2">Owner/Admin Actions</p>
                                <div class="d-flex gap-2">
                                    @if (isOwner)
                                    {
                                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm px-3 shadow-sm">
                                            <i class="bi bi-pencil-square me-1"></i> Edit Details
                                        </a>
                                    }
                                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                                          onsubmit="return confirm('Are you sure you want to delete this car?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-danger btn-sm px-3 shadow-sm">
                                            <i class="bi bi-trash me-1"></i> Delete
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>