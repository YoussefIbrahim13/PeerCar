@using Peer_Car.Domain.Entities
@model Car

@{
    ViewData["Title"] = "Edit & Resubmit Car";
}

<div class="hero-section position-relative mb-5 bg-danger text-white py-5 shadow-sm">
    <div class="container position-relative">
        <div class="row">
            <div class="col-lg-8 col-md-10 mx-auto text-center">
                <h1 class="display-4 fw-bold mb-3">Resubmit Your Car</h1>
                <p class="lead mb-0">Update your details and documents to meet the requirements.</p>
            </div>
        </div>
    </div>
</div>

<div class="container mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            @if (!string.IsNullOrEmpty(Model.RejectionReason))
            {
                <div class="alert alert-danger border-0 shadow-sm mb-4 d-flex align-items-center" role="alert">
                    <i class="bi bi-exclamation-octagon-fill fs-3 me-3"></i>
                    <div>
                        <h5 class="alert-heading fw-bold mb-1">Reason for Previous Rejection:</h5>
                        <p class="mb-0">@Model.RejectionReason</p>
                    </div>
                </div>
            }

            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-4 p-md-5">
                    <form asp-controller="Cars" asp-action="EditRejected" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="OwnerId" />
                        <input type="hidden" asp-for="CreatedAt" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-warning mb-4"></div>

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label asp-for="Brand" class="form-label fw-bold">Brand</label>
                                <input asp-for="Brand" class="form-control" placeholder="e.g. Toyota" />
                                <span asp-validation-for="Brand" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Model" class="form-label fw-bold">Model</label>
                                <input asp-for="Model" class="form-control" placeholder="e.g. Corolla" />
                                <span asp-validation-for="Model" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Year" class="form-label fw-bold">Year</label>
                                <input asp-for="Year" class="form-control" type="number" />
                                <span asp-validation-for="Year" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="PricePerDay" class="form-label fw-bold">Price Per Day (SAR)</label>
                                <input asp-for="PricePerDay" class="form-control" step="0.01" />
                                <span asp-validation-for="PricePerDay" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Location" class="form-label fw-bold">Location</label>
                                <input asp-for="Location" class="form-control" placeholder="Enter city or area" />
                                <span asp-validation-for="Location" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">New Car Image (Optional)</label>
                                <input type="file" name="CarImage" class="form-control" accept="image/*" />
                                <div class="form-text">Upload only if you want to change the current photo.</div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">Official Document (Required)</label>
                                <input type="file" name="CarDocument" class="form-control" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png" />
                                <div class="form-text">Proof of ownership or insurance.</div>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-5">
                            <button type="submit" class="btn btn-primary btn-lg fw-bold shadow-sm">
                                <i class="bi bi-send-check me-2"></i>Resubmit for Approval
                            </button>
                            <a asp-action="MyCars" class="btn btn-link text-decoration-none text-muted">Cancel and Back</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}