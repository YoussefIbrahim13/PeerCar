@using Microsoft.AspNetCore.Identity
@using Peer_Car.Domain.Entities
@inject SignInManager<User> SignInManager

@{
    ViewData["Title"] = "Home Page";
    bool isAdmin = User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin");
}

<div class="hero-section position-relative mb-5" style="background: linear-gradient(135deg, #0d6efd 0%, #212529 100%); min-height: 400px; border-radius: 0 0 3rem 3rem;">
    <div class="container position-relative py-5">
        <div class="row align-items-center py-5">
            <div class="col-lg-8 mx-auto text-center text-white">
                <h1 class="display-1 fw-bold mb-3 animate__animated animate__fadeInDown">Drive Your Way</h1>
                <p class="lead fs-3 mb-5 animate__animated animate__fadeInUp opacity-75">PeerCar: The ultimate platform for seamless car rentals and peer-to-peer sharing.</p>
                <div class="d-flex justify-content-center gap-3">
                    <a asp-controller="Cars" asp-action="Index" class="btn btn-lg btn-primary px-5 py-3 rounded-pill shadow-lg fw-bold">
                        <i class="bi bi-search me-2"></i>Browse Cars
                    </a>
                    @if (!SignInManager.IsSignedIn(User))
                    {
                        <a asp-controller="Account" asp-action="Register" class="btn btn-lg btn-outline-light px-5 py-3 rounded-pill fw-bold">
                            Join Now
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container mb-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="fw-bold mb-0">Quick Actions</h2>
            <p class="text-muted mb-0">Everything you need to get started quickly</p>
        </div>
    </div>
    
    <div class="row g-4">
        <div class="col-md-4">
            <div class="quick-action-card card h-100 border-0 shadow-sm p-4">
                <div class="quick-action-icon mb-3 bg-primary text-white shadow-sm">
                    <i class="bi bi-car-front"></i>
                </div>
                <h5 class="fw-bold">Find a Ride</h5>
                <p class="text-muted small">Explore our diverse fleet of vehicles tailored for every journey.</p>
                <a asp-controller="Cars" asp-action="Index" class="btn btn-light rounded-pill mt-auto">Browse All</a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="quick-action-card card h-100 border-0 shadow-sm p-4">
                @{
                    var bookingController = isAdmin ? "Admin" : "Bookings";
                    var bookingAction = isAdmin ? "UserReservations" : "MyBookings";
                    var bookingTitle = isAdmin ? "Platform Reservations" : "My Bookings";
                    var bookingIcon = isAdmin ? "bi-shield-check" : "bi-calendar-check";
                    var iconColor = isAdmin ? "bg-dark" : "bg-success";
                }
                <div class="quick-action-icon mb-3 @iconColor text-white shadow-sm">
                    <i class="bi @bookingIcon"></i>
                </div>
                <h5 class="fw-bold">@bookingTitle</h5>
                <p class="text-muted small">@(isAdmin ? "Manage and monitor all active bookings on the platform." : "Track and manage your upcoming and past car rentals.")</p>
                <a asp-controller="@bookingController" asp-action="@bookingAction" class="btn btn-light rounded-pill mt-auto">View Details</a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="quick-action-card card h-100 border-0 shadow-sm p-4">
                <div class="quick-action-icon mb-3 bg-info text-white shadow-sm">
                    <i class="bi bi-person-gear"></i>
                </div>
                <h5 class="fw-bold">@(SignInManager.IsSignedIn(User) ? "Edit Profile" : "Account")</h5>
                <p class="text-muted small">Update your personal information, profile picture, and contact details.</p>

                <a asp-controller="Account"
                   asp-action="@(SignInManager.IsSignedIn(User) ? "EditProfile" : "Login")"
                   class="btn btn-light rounded-pill mt-auto">Edit My Data</a>
            </div>
        </div>
    </div>
</div>

<div class="container mb-5 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0 text-dark"><i class="bi bi-stars text-warning me-2"></i>Recently Added</h2>
        <a asp-controller="Cars" asp-action="Index" class="text-primary text-decoration-none fw-bold">View More <i class="bi bi-arrow-right"></i></a>
    </div>
    
    <div class="row g-4">
        @* ViewComponent لاستدعاء أحدث السيارات *@
        @await Component.InvokeAsync("RecentCars")
    </div>
</div>

@if (isAdmin)
{
    <div class="container mb-5">
        <div class="card border-0 shadow-lg rounded-4 bg-light border-start border-4 border-primary">
            <div class="card-body p-4 p-md-5">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <h3 class="fw-bold text-dark"><i class="bi bi-speedometer2 me-2"></i>Admin Management Console</h3>
                        <p class="text-muted">Direct access to users, vehicle fleet, and platform-wide analytics.</p>
                    </div>
                    <div class="col-md-4 text-md-end">
                        <div class="btn-group shadow-sm">
                            <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-primary">Dashboard</a>
                            <button type="button" class="btn btn-primary dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown"></button>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Users"><i class="bi bi-people me-2"></i>Users List</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Cars"><i class="bi bi-car-front me-2"></i>Fleet Manager</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="UserReservations"><i class="bi bi-journal-text me-2"></i>Bookings Log</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .quick-action-card { border-radius: 1.5rem; transition: all 0.3s ease; }
    .quick-action-card:hover { transform: translateY(-10px); box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important; background: #fff; }
    .quick-action-icon { width: 60px; height: 60px; display: flex; align-items: center; justify-content: center; border-radius: 1rem; font-size: 1.8rem; }
    .hero-section h1 { letter-spacing: -2px; }
</style>