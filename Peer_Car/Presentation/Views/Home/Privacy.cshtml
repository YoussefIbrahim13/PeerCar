@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="hero-section position-relative mb-5" style="background: linear-gradient(135deg, #212529 0%, #0d6efd 100%); min-height: 250px; border-radius: 0 0 2.5rem 2.5rem;">
    <div class="container position-relative py-5 text-center text-white">
        <h1 class="display-3 fw-bold mb-2 animate__animated animate__fadeInDown">Privacy Policy</h1>
        <p class="lead opacity-75 animate__animated animate__fadeInUp">How we protect and manage your data at PeerCar</p>
    </div>
</div>

<div class="container mb-5">
    <div class="row">
        <div class="col-lg-9 mx-auto">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-body p-4 p-md-5">
                    
                    <div class="d-flex align-items-center mb-4">
                        <div class="icon-box bg-primary-subtle text-primary rounded-circle p-3 me-3">
                            <i class="bi bi-shield-lock-fill fs-3"></i>
                        </div>
                        <h3 class="fw-bold mb-0">Our Commitment to Privacy</h3>
                    </div>
                    
                    <p class="text-muted fs-5 mb-5">
                        At <strong>PeerCar</strong>, we respect your privacy and are committed to protecting your personal data. This policy explains how we collect, use, and safeguard your information when you use our car-sharing platform.
                    </p>

                    <div class="mb-5">
                        <h5 class="fw-bold text-dark mb-3"><i class="bi bi-collect me-2 text-primary"></i>1. Information We Collect</h5>
                        <p class="text-muted">We collect information you provide directly to us when you:</p>
                        <div class="row g-3 ms-1">
                            <div class="col-md-6">
                                <ul class="list-group list-group-flush small">
                                    <li class="list-group-item border-0 px-0"><i class="bi bi-check2-circle me-2 text-success"></i>Account Registration</li>
                                    <li class="list-group-item border-0 px-0"><i class="bi bi-check2-circle me-2 text-success"></i>Vehicle Booking & Listing</li>
                                </ul>
                            </div>
                            <div class="col-md-6">
                                <ul class="list-group list-group-flush small">
                                    <li class="list-group-item border-0 px-0"><i class="bi bi-check2-circle me-2 text-success"></i>Identity Verification (ID/License)</li>
                                    <li class="list-group-item border-0 px-0"><i class="bi bi-check2-circle me-2 text-success"></i>Payment Processing Details</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="mb-5 p-4 bg-light rounded-3 border-start border-4 border-primary">
                        <h5 class="fw-bold text-dark mb-3">2. How We Use Your Information</h5>
                        <p class="text-muted mb-0">Your data helps us maintain a secure environment, process transactions efficiently, detect fraudulent activities, and improve your overall car-sharing experience.</p>
                    </div>

                    <div class="mb-5">
                        <h5 class="fw-bold text-dark mb-3"><i class="bi bi-safe2 me-2 text-primary"></i>3. Data Security</h5>
                        <p class="text-muted">
                            We implement enterprise-grade security measures to protect your personal information. As experts in software engineering, we ensure that your sensitive data (like licenses and passwords) is handled with the highest encryption standards.
                        </p>
                    </div>

                    <div class="mb-5">
                        <h5 class="fw-bold text-dark mb-3"><i class="bi bi-person-check me-2 text-primary"></i>4. Your Rights</h5>
                        <p class="text-muted">
                            You have the right to access, update, or request the deletion of your personal information. You can manage most of these settings directly through your <a asp-controller="Users" asp-action="MyAccount" class="text-primary text-decoration-none fw-bold">Account Dashboard</a>.
                        </p>
                    </div>

                    <div class="alert alert-primary border-0 shadow-sm rounded-3 mt-5 p-4">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-info-circle-fill fs-3 me-3"></i>
                            <div>
                                <h6 class="fw-bold mb-1">Questions or Concerns?</h6>
                                <p class="mb-0 small">Our team is here to help. Reach out to us at <a href="mailto:privacy@peercar.com" class="fw-bold text-primary">privacy@peercar.com</a></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <p class="text-center mt-4 text-muted small">
                Last updated: @DateTime.Now.ToString("MMMM dd, yyyy")
            </p>
        </div>
    </div>
</div>

<style>
    .rounded-4 { border-radius: 1.5rem !important; }
    .icon-box { width: 60px; height: 60px; display: flex; align-items: center; justify-content: center; }
    .list-group-item { background: transparent; }
</style>