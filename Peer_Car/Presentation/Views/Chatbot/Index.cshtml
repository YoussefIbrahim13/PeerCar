@{
    ViewData["Title"] = "PeerCar AI Assistant";
    ViewData["HideFooter"] = true;
}

<link rel="stylesheet" href="~/css/chatbot.css" asp-append-version="true" />

<div class="chat-main-wrapper">
    <div class="chat-container shadow-lg">
        <div class="chat-header">
            <div class="d-flex align-items-center">
                <div class="avatar-status">
                    <img src="https://cdn-icons-png.flaticon.com/512/4712/4712035.png" alt="AI" />
                    <span class="status-dot"></span>
                </div>
                <div class="ms-3">
                    <h5 class="mb-0 fw-bold">PeerCar Assistant</h5>
                    <small class="opacity-75">AI-Powered Car Guide</small>
                </div>
            </div>
        </div>

        <div id="chatMessages" class="chat-messages p-4">
            <div class="message assistant-msg">
                <div class="text">أهلاً يا @User.Identity?.Name! أنا مساعدك الذكي في PeerCar. محتاج مساعدة في اختيار عربية لرحلتك الجاية؟ 🚗</div>
                <small class="time">@DateTime.Now.ToString("t")</small>
            </div>
        </div>

        <div class="chat-input-area p-3">
            <form id="chatForm" class="input-group shadow-sm rounded-pill overflow-hidden bg-white">
                <input type="text" id="userInput" class="form-control border-0 px-4" placeholder="اسألني عن أي عربية..." autocomplete="off" />
                <button class="btn btn-primary px-4" type="submit" id="sendBtn">
                    <i class="bi bi-send-fill"></i>
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script src="~/js/chatbot.js" asp-append-version="true"></script>
}