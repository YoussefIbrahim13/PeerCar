@{
    ViewData["Title"] = "Email Confirmed";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center py-5">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-lg rounded-4 text-center overflow-hidden">
                <div class="bg-success py-2"></div>
                
                <div class="card-body p-5">
                    <div class="mb-4">
                        <div class="icon-circle bg-success-subtle text-success d-inline-flex align-items-center justify-content-center rounded-circle" style="width: 100px; height: 100px;">
                            <i class="bi bi-check-all display-1"></i>
                        </div>
                    </div>

                    <h2 class="fw-bold mb-3 text-dark">Email Confirmed!</h2>
                    
                    <p class="text-muted fs-5 mb-5">
                        Your email address has been successfully verified. 
                        Your <strong>PeerCar</strong> account is now fully active and ready for use.
                    </p>

                    <div class="d-grid gap-3">
                        <a asp-controller="Account" asp-action="Login" class="btn btn-success btn-lg rounded-pill fw-bold shadow-sm py-3">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Continue to Login
                        </a>
                        
                        <a asp-controller="Home" asp-action="Index" class="btn btn-link text-muted text-decoration-none small">
                            Go to Home Page
                        </a>
                    </div>
                </div>
            </div>

            <p class="text-center mt-4 text-muted small">
                Step 3 of 3: Verification Complete <i class="bi bi-flag-fill ms-1 text-success"></i>
            </p>
        </div>
    </div>
</div>

<style>
    /* لمسة جمالية خفيفة */
    .rounded-4 { border-radius: 2rem !important; }
    .icon-circle { 
        animation: bounceIn 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55); 
    }
    
    @@keyframes bounceIn {
        0% { transform: scale(0.3); opacity: 0; }
        50% { transform: scale(1.05); opacity: 1; }
        70% { transform: scale(0.9); }
        100% { transform: scale(1); }
    }
</style>