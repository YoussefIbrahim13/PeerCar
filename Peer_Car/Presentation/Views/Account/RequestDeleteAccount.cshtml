@{
    ViewData["Title"] = "Delete Account";
}

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-danger py-2"></div>
                
                <div class="card-body p-5 text-center">
                    <div class="mb-4">
                        <div class="icon-box bg-danger-subtle text-danger d-inline-flex align-items-center justify-content-center rounded-circle" style="width: 80px; height: 80px;">
                            <i class="bi bi-exclamation-triangle-fill display-4"></i>
                        </div>
                    </div>

                    <h2 class="fw-bold mb-3 text-dark">Delete Your Account?</h2>
                    
                    <div class="alert alert-danger border-0 shadow-sm rounded-3 mb-4">
                        <p class="mb-0 fw-semibold">
                            <i class="bi bi-info-circle me-2"></i> 
                            This action is <strong>permanent</strong> and cannot be undone once confirmed.
                        </p>
                    </div>

                    <p class="text-muted mb-5 px-lg-3">
                        To protect your data, we will send a <strong>confirmation link</strong> to your email address. 
                        Your account will only be scheduled for deletion after you click that link.
                    </p>

                    <form asp-controller="Users" asp-action="SubmitDeleteAccountRequest" method="post">
                        @Html.AntiForgeryToken()
                        
                        <div class="d-grid gap-3">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill fw-bold shadow-sm py-3">
                                <i class="bi bi-envelope-check me-2"></i>Send Confirmation Email
                            </button>
                            
                            <a asp-action="MyAccount" class="btn btn-outline-secondary btn-lg rounded-pill fw-bold">
                                No, Keep My Account
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <div class="text-center mt-4">
                <p class="text-muted small">
                    <i class="bi bi-shield-lock me-1"></i> 
                    Your privacy and data security are our top priorities.
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-4 { border-radius: 1.5rem !important; }
    .bg-danger-subtle { background-color: #f8d7da !important; }
    .card { transition: transform 0.3s ease; }
    /* أنيميشن خفيف عشان يحس برهبة الموقف */
    .icon-box i {
        animation: shake 0.5s infinite;
    }
    @@keyframes shake {
        0% { transform: rotate(0deg); }
        25% { transform: rotate(5deg); }
        50% { transform: rotate(0deg); }
        75% { transform: rotate(-5deg); }
        100% { transform: rotate(0deg); }
    }
</style>