@{
    ViewData["Title"] = "Registration Confirmation";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center py-5">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-lg rounded-4 text-center overflow-hidden">
                <div class="bg-info py-2"></div>
                
                <div class="card-body p-5">
                    <div class="mb-4">
                        <div class="icon-circle bg-info-subtle text-info d-inline-flex align-items-center justify-content-center rounded-circle shadow-sm" style="width: 90px; height: 90px;">
                            <i class="bi bi-send-check-fill display-4"></i>
                        </div>
                    </div>

                    <h2 class="fw-bold mb-3 text-dark">Welcome to PeerCar!</h2>
                    
                    <h5 class="text-primary mb-4">Registration Successful!</h5>
                    
                    <p class="text-muted fs-5 mb-4">
                        We've sent a <strong>confirmation link</strong> to your email address. 
                        Please check your inbox and click the link to activate your account.
                    </p>

                    <div class="alert alert-light border shadow-sm rounded-3 mb-5 py-3 small">
                        <i class="bi bi-info-circle me-2 text-info"></i>
                        If you don't see the email within a few minutes, please check your <strong>Spam</strong> folder.
                    </div>

                    <div class="d-grid gap-2">
                        <a href="/" class="btn btn-info text-white btn-lg rounded-pill fw-bold shadow-sm py-3">
                            <i class="bi bi-house-door me-2"></i>Return to Home
                        </a>
                        <a asp-action="Login" class="btn btn-link text-muted text-decoration-none">
                            Go to Login Page
                        </a>
                    </div>
                </div>
            </div>
            
            <p class="text-center mt-4 text-muted small">
                Having trouble? <a href="mailto:support@peercar.com" class="text-info text-decoration-none">Contact Support</a>
            </p>
        </div>
    </div>
</div>

<style>
    .rounded-4 { border-radius: 2rem !important; }
    .bg-info-subtle { background-color: #e1f5fe !important; }
    .icon-circle { 
        animation: slideInUp 0.6s ease-out; 
    }
    @@keyframes slideInUp {
        from { transform: translateY(20px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }
</style>