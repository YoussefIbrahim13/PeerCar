@{
    ViewData["Title"] = "Email Sent";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center py-5">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-success py-1"></div>

                <div class="card-body p-4 p-md-5 text-center">
                    <div class="icon-box bg-success-subtle text-success d-inline-flex align-items-center justify-content-center rounded-circle mb-4" style="width: 80px; height: 80px;">
                        <i class="bi bi-envelope-check-fill fs-1"></i>
                    </div>

                    <h3 class="fw-bold text-dark mb-3">Check Your Email</h3>
                    <p class="text-muted">
                        If an account exists for that email, we have sent a password reset link.
                        Please check your inbox (and spam folder) to continue.
                    </p>

                    <div class="d-grid mt-4">
                        <a asp-action="Login" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm py-3">
                            Back to Login
                        </a>
                    </div>
                </div>
            </div>

            <p class="text-center mt-4 small text-muted">
                Didn't get an email? <a asp-action="ForgotPassword" class="text-decoration-none">Try again</a>
            </p>
        </div>
    </div>
</div>