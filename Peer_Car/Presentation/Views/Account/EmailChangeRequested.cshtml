@{
    ViewData["Title"] = "Email Change Requested";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-primary py-2"></div>
                
                <div class="card-body p-5 text-center">
                    <div class="mb-4">
                        <div class="icon-circle bg-primary-subtle text-primary d-inline-flex align-items-center justify-content-center rounded-circle" style="width: 80px; height: 80px;">
                            <i class="bi bi-envelope-check-fill display-4"></i>
                        </div>
                    </div>

                    <h3 class="fw-bold mb-3 text-dark">Check Your Inbox!</h3>
                    
                    <p class="text-muted fs-5 mb-4">
                        We've sent a confirmation link to your <strong>new email address</strong>. 
                        Please click the link in that email to verify and complete the change.
                    </p>

                    <div class="alert alert-warning border-0 shadow-sm rounded-3 mb-4 py-3">
                        <div class="d-flex align-items-center justify-content-center">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <span class="small fw-semibold">Don't see it? Check your <strong>Spam</strong> or Junk folder.</span>
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <a href="/" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm">
                            <i class="bi bi-house-door me-2"></i>Return to Home
                        </a>
                        <a asp-action="Profile" class="btn btn-link text-muted text-decoration-none small">
                            Go to My Profile
                        </a>
                    </div>
                </div>
            </div>
            
            <p class="text-center mt-4 text-muted small">
                &copy; @DateTime.Now.Year PeerCar Platform. All rights reserved.
            </p>
        </div>
    </div>
</div>

<style>
    .rounded-4 { border-radius: 1.5rem !important; }
    .icon-circle { transition: transform 0.3s ease; }
    .card:hover .icon-circle { transform: scale(1.1); }
</style>