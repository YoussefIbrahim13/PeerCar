@using Peer_Car.Application.ViewModels
@model RegisterViewModel

@{
    ViewData["Title"] = "Join PeerCar";
}

<div class="hero-section position-relative mb-5 bg-dark text-white py-5 shadow-sm">
    <div class="container position-relative text-center py-4">
        <h1 class="display-3 fw-bold mb-2 animate__animated animate__fadeInDown">Join PeerCar</h1>
        <p class="lead fs-4 animate__animated animate__fadeInUp opacity-75">Create an account to start renting and sharing cars today</p>
    </div>
</div>

<div class="container mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-10">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-primary py-1"></div>
                
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <div class="icon-box bg-primary-subtle text-primary d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 60px; height: 60px;">
                            <i class="bi bi-person-plus fs-2"></i>
                        </div>
                        <h4 class="fw-bold text-dark">Create Your Account</h4>
                    </div>
                    
                    <form asp-controller="Account" asp-action="Register" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-4"></div>
                        
                        <div class="row g-3">
                            <div class="col-md-6 mb-3">
                                <label asp-for="FirstName" class="form-label fw-bold small text-uppercase text-secondary">First Name</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-person text-muted"></i></span>
                                    <input asp-for="FirstName" class="form-control border-start-0" placeholder="Youssef" />
                                </div>
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="LastName" class="form-label fw-bold small text-uppercase text-secondary">Last Name</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-person text-muted"></i></span>
                                    <input asp-for="LastName" class="form-control border-start-0" placeholder="Ibrahim" />
                                </div>
                                <span asp-validation-for="LastName" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mb-3">
                                <label asp-for="Email" class="form-label fw-bold small text-uppercase text-secondary">Gmail Address</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope-at text-muted"></i></span>
                                    <input asp-for="Email" class="form-control border-start-0" placeholder="example@gmail.com"
                                           pattern="^[a-zA-Z0-9._%+-]+@@gmail.com$"
                                           title="Only Gmail addresses are allowed." required />
                                </div>
                                <div class="form-text small">We only accept Gmail accounts for security verification.</div>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mb-3">
                                <label asp-for="PhoneNumber" class="form-label fw-bold small text-uppercase text-secondary">Egyptian Phone Number</label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light border-end-0 text-muted small fw-bold">+20</span>
                                    <input asp-for="PhoneNumber" class="form-control border-start-0" placeholder="1xxxxxxxxx"
                                           pattern="^1[0-9]{9}$" maxlength="10" required
                                           oninput="this.value = this.value.replace(/[^0-9]/g, ''); updatePhonePreview(this.value);" />
                                </div>
                                <div id="phonePreview" class="small mt-1 text-primary fw-bold" style="display:none;"></div>
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Password" class="form-label fw-bold small text-uppercase text-secondary">Password</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-lock text-muted"></i></span>
                                    <input asp-for="Password" class="form-control border-start-0 border-end-0" type="password" id="passwordInput" placeholder="••••••••" />
                                    <button class="btn btn-light border border-start-0" type="button" onclick="togglePass('passwordInput', 'togglePasswordIcon')">
                                        <i class="bi bi-eye text-muted" id="togglePasswordIcon"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="ConfirmPassword" class="form-label fw-bold small text-uppercase text-secondary">Confirm Password</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-shield-lock text-muted"></i></span>
                                    <input asp-for="ConfirmPassword" class="form-control border-start-0 border-end-0" type="password" id="confirmPasswordInput" placeholder="••••••••" />
                                    <button class="btn btn-light border border-start-0" type="button" onclick="togglePass('confirmPasswordInput', 'toggleConfirmPasswordIcon')">
                                        <i class="bi bi-eye text-muted" id="toggleConfirmPasswordIcon"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4 mt-2">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="termsCheck" required />
                                <label class="form-check-label small text-muted" for="termsCheck">
                                    I agree to the <a href="#" class="text-primary text-decoration-none fw-bold">Terms and Conditions</a>
                                </label>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm py-3">
                                <i class="bi bi-person-check me-2"></i>Create My Account
                            </button>
                        </div>
                    </form>

                    <div class="text-center mt-4 pt-3 border-top">
                        <p class="text-muted small mb-0">Already a member? <a asp-action="Login" class="text-primary fw-bold text-decoration-none">Sign In Here</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // دمج وظائف الـ Toggle في ميثود واحدة أنضف
        function togglePass(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            const isPassword = input.type === 'password';
            input.type = isPassword ? 'text' : 'password';
            icon.classList.toggle('bi-eye');
            icon.classList.toggle('bi-eye-slash');
        }

        function updatePhonePreview(val) {
            const preview = document.getElementById("phonePreview");
            if (/^1[0-9]{9}$/.test(val)) {
                preview.style.display = "block";
                preview.textContent = "Preview: +20 " + val;
            } else {
                preview.style.display = "none";
            }
        }
    </script>
}