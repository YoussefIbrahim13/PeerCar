@using Peer_Car.Application.ViewModels
@using Microsoft.AspNetCore.Identity
@using Peer_Car.Domain.Entities
@model EditProfileViewModel
@inject UserManager<User> UserManager

@{
    ViewData["Title"] = "Account Details";

    // التحقق هل اليوزر اللي فاتح الصفحة هو صاحب الحساب فعلاً
    var loggedInUserId = UserManager.GetUserId(User);
    bool isMyProfile = loggedInUserId != null && Guid.Parse(loggedInUserId) == Model.UserId;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-10 col-lg-8">
            <div class="account-card shadow-lg border-0 p-4">
                <div class="card-body">

                    @* 1. Profile Header: Image & Basic Info *@
                    <div class="text-center">
                        <div class="mb-4 profile-image-container">
                            @{
                                var rawImg = Model.ProfileImageUrl;
                                var finalPath = string.IsNullOrEmpty(rawImg) || rawImg == "default.png"
                                                ? "/images/profiles/default.png"
                                                : (rawImg.StartsWith("/images") ? rawImg : "/images/profiles/" + rawImg);
                            }
                            <img src="@finalPath"
                                 asp-append-version="true"
                                 class="rounded-circle shadow-sm border border-4 border-white mx-auto d-block img-fluid profile-trigger"
                                 alt="Profile Picture"
                                 data-bs-toggle="modal" data-bs-target="#profileImageModal" />
                        </div>

                        <h2 class="fw-bold mb-2 mt-3 text-dark">@Model.FullName</h2>

                        <div class="mb-2">
                            <span class="badge bg-light text-primary px-3 py-2 rounded-pill">
                                <i class="bi bi-envelope-at me-2"></i>@Model.Email
                            </span>
                        </div>

                        <div class="mb-4">
                            <span class="text-muted small">
                                <i class="bi bi-telephone me-1"></i>+20 @Model.PhoneNumber
                            </span>
                        </div>
                    </div>

                    @* 🛡️ 2. Verification Documents (Visible to Owner of account or Car Owner who has a booking) *@
                    @if (Model.IsOwnerViewing || isMyProfile)
                    {
                        @if (!string.IsNullOrEmpty(Model.NationalIdFrontUrl))
                        {
                            <hr class="my-5">
                            <div class="documents-section">
                                <h5 class="fw-bold mb-4 text-dark border-start border-primary border-4 ps-3">
                                    <i class="bi bi-shield-check me-2 text-primary"></i>Verification Documents
                                </h5>

                                <div class="row g-4 text-center">
                                    <div class="col-md-6">
                                        <p class="small fw-bold text-muted text-uppercase mb-3">National ID</p>
                                        <div class="d-flex justify-content-center gap-2">
                                            <a href="@Model.NationalIdFrontUrl" target="_blank" class="doc-preview">
                                                <img src="@Model.NationalIdFrontUrl" class="rounded-3 shadow-sm border" />
                                            </a>
                                            <a href="@Model.NationalIdBackUrl" target="_blank" class="doc-preview">
                                                <img src="@Model.NationalIdBackUrl" class="rounded-3 shadow-sm border" />
                                            </a>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <p class="small fw-bold text-muted text-uppercase mb-3">Driving License</p>
                                        <div class="d-flex justify-content-center gap-2">
                                            <a href="@Model.LicenseFrontUrl" target="_blank" class="doc-preview">
                                                <img src="@Model.LicenseFrontUrl" class="rounded-3 shadow-sm border" />
                                            </a>
                                            <a href="@Model.LicenseBackUrl" target="_blank" class="doc-preview">
                                                <img src="@Model.LicenseBackUrl" class="rounded-3 shadow-sm border" />
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }

                    @* 3. Action Buttons & Controls *@
                    <div class="text-center mt-5 pt-4 border-top">
                        @if (isMyProfile)
                        {
                            @* --- خيارات صاحب الحساب --- *@
                            <div class="d-flex flex-column flex-md-row justify-content-center gap-3">
                                <a asp-action="EditProfile" class="btn btn-warning btn-lg px-4 rounded-pill fw-bold shadow-sm">
                                    <i class="bi bi-pencil-square me-2"></i> Edit Profile
                                </a>

                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-dark btn-lg px-4 rounded-pill fw-bold">
                                        <i class="bi bi-box-arrow-right me-2"></i> Logout
                                    </button>
                                </form>
                            </div>

                            @* Danger Zone (Delete Account) *@
                            <div class="mt-5 p-3 bg-danger-subtle rounded-4">
                                <p class="text-danger small fw-bold mb-2"><i class="bi bi-exclamation-triangle me-1"></i> Danger Zone</p>
                                <form asp-action="DeleteAccount" method="post" onsubmit="return confirm('Are you sure? This action cannot be undone and your account will be permanently removed.');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-link text-danger text-decoration-none small p-0">
                                        <i class="bi bi-trash me-1"></i> Permanent Delete Account
                                    </button>
                                </form>
                            </div>
                        }
                        else
                        {
                            @* --- خيارات الزائر (محمد مثلاً) --- *@
                            <div class="mt-2">
                                <a asp-controller="Cars" asp-action="Index" asp-route-ownerId="@Model.UserId" class="btn btn-primary btn-lg rounded-pill px-5 shadow">
                                    <i class="bi bi-car-front-fill me-2"></i> View This User's Cars
                                </a>
                            </div>
                        }
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@* Modal for Profile Image Zoom *@
<div class="modal fade" id="profileImageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-transparent border-0 shadow-none">
            <div class="modal-body p-0 text-center">
                <img src="@finalPath" class="img-fluid rounded shadow-lg modal-zoom-img" />
            </div>
        </div>
    </div>
</div>

<style>
    .account-card {
        border-radius: 2rem;
        background: #ffffff;
    }

    .profile-trigger {
        width: 180px;
        height: 180px;
        object-fit: cover;
        cursor: zoom-in;
    }

    .modal-zoom-img {
        max-width: 95%;
        max-height: 85vh;
        object-fit: contain;
    }

    .doc-preview img {
        width: 140px;
        height: 90px;
        object-fit: cover;
        transition: 0.3s;
    }

        .doc-preview img:hover {
            transform: scale(1.05);
            filter: brightness(0.9);
        }

    .bg-danger-subtle {
        background-color: #f8d7da;
    }
</style>