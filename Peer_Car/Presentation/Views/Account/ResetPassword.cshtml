@using Peer_Car.Application.ViewModels
@model ResetPasswordViewModel

@{
    ViewData["Title"] = "Reset Password";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center py-5">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-primary py-1"></div>
                
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <div class="icon-box bg-primary-subtle text-primary d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 70px; height: 70px;">
                            <i class="bi bi-shield-lock-fill fs-2"></i>
                        </div>
                        <h3 class="fw-bold text-dark">Create New Password</h3>
                        <p class="text-muted small">Please enter your new password below to regain access to your account.</p>
                    </div>

                    <form asp-controller="Account" asp-action="ResetPassword" method="post">
                        @Html.AntiForgeryToken()
                        
                        <input type="hidden" asp-for="Email" />
                        <input type="hidden" asp-for="Token" />
                        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-4"></div>

                        <div class="mb-4">
                            <label asp-for="NewPassword" class="form-label fw-bold small text-uppercase text-secondary">New Password</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="bi bi-key text-muted"></i></span>
                                <input asp-for="NewPassword" class="form-control form-control-lg border-start-0 border-end-0 fs-6" 
                                       type="password" id="newPasswordInput" placeholder="••••••••" />
                                <button class="btn btn-light border border-start-0" type="button" onclick="togglePass('newPasswordInput', 'toggleNewPasswordIcon')">
                                    <i class="bi bi-eye text-muted" id="toggleNewPasswordIcon"></i>
                                </button>
                            </div>
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label fw-bold small text-uppercase text-secondary">Confirm Password</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="bi bi-shield-check text-muted"></i></span>
                                <input asp-for="ConfirmPassword" class="form-control border-start-0 border-end-0 fs-6" 
                                       type="password" id="confirmPasswordInput" placeholder="••••••••" />
                                <button class="btn btn-light border border-start-0" type="button" onclick="togglePass('confirmPasswordInput', 'toggleConfirmPasswordIcon')">
                                    <i class="bi bi-eye text-muted" id="toggleConfirmPasswordIcon"></i>
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm py-3 fs-6">
                                <i class="bi bi-check2-circle me-2"></i>Reset Password
                            </button>
                        </div>
                    </form>
                </div>
            </div>
            
            <div class="text-center mt-4">
                <a asp-action="Login" class="text-muted small text-decoration-none">
                    <i class="bi bi-arrow-left me-1"></i> Remembered it? Back to Login
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        // ميثود موحدة للـ Toggle Password عشان الكود يكون أنظف
        function togglePass(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            const isPassword = input.type === 'password';
            input.type = isPassword ? 'text' : 'password';
            icon.classList.toggle('bi-eye');
            icon.classList.toggle('bi-eye-slash');
        }
    </script>
}

<style>
    .rounded-4 { border-radius: 1.5rem !important; }
    .input-group:focus-within { box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15); border-radius: 0.375rem; }
</style>